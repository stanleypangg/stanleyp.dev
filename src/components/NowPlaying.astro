---
// NowPlaying fetches /api/now-playing on the client and renders inline.
// No visible content during SSG — entirely driven by client-side fetch.
---

<div class="np-wrap" id="np-wrap" aria-live="polite">
  <div class="np-skel" aria-hidden="true">
    <div class="np-skel-art"></div>
    <div class="np-skel-lines">
      <div class="np-skel-line np-skel-line--title"></div>
      <div class="np-skel-line np-skel-line--artist"></div>
    </div>
  </div>
</div>

<script>
  import { esc } from '../lib/music-utils';

  interface NowPlayingData {
    isPlaying: boolean;
    title: string | null;
    artist?: string;
    albumImageUrl?: string;
    songUrl?: string;
  }

  function setLabel(text: string) {
    const label = document.getElementById('listening-label');
    if (label) label.textContent = text;
  }

  function render(data: NowPlayingData) {
    const wrap = document.getElementById('np-wrap');
    if (!wrap) return;

    if (!data.title) {
      setLabel('Listening');
      wrap.innerHTML = `<span class="np-idle">
        <img class="np-cat" src="/cat-sleeping.gif" alt="Sleeping cat" width="40" height="40" />
        Not listening right now
      </span>`;
      return;
    }

    setLabel(data.isPlaying ? 'Listening' : 'Last listened');

    const statusDot = `<span class="np-wave${data.isPlaying ? ' np-wave--live' : ''}" aria-label="${data.isPlaying ? 'Now playing' : 'Last played'}">
      <span class="np-bar"></span>
      <span class="np-bar"></span>
      <span class="np-bar"></span>
      <span class="np-bar"></span>
    </span>`;

    const safeImageUrl = data.albumImageUrl?.startsWith('https://') ? esc(data.albumImageUrl) : '';
    const catUrl = data.isPlaying ? '/cat-bopping.webp' : '/cat-sleeping.gif';
    const img = safeImageUrl
      ? `<span class="np-flip">
           <span class="np-flip-inner">
             <span class="np-flip-front">
               <img class="np-art" src="${safeImageUrl}" alt="" width="40" height="40" loading="lazy" />
             </span>
             <span class="np-flip-back">
               <img class="np-art np-art-cat" src="${catUrl}" alt="${data.isPlaying ? 'Bopping cat' : 'Sleeping cat'}" width="40" height="40" />
             </span>
           </span>
         </span>`
      : '';

    const safeSongUrl = data.songUrl?.startsWith('https://') ? esc(data.songUrl) : null;
    const title = esc(data.title ?? '');
    const artist = esc(data.artist ?? '');

    const link = safeSongUrl
      ? `<a class="np-track" href="${safeSongUrl}" target="_blank" rel="noopener noreferrer">
           <span class="np-title">${title}</span>
           <span class="np-artist">${artist}</span>
         </a>`
      : `<span class="np-track">
           <span class="np-title">${title}</span>
           <span class="np-artist">${artist}</span>
         </span>`;

    wrap.innerHTML = `${img}${link}${statusDot}`;
  }

  async function load() {
    try {
      const res = await fetch('/api/now-playing');
      if (!res.ok) return;
      const data: NowPlayingData = await res.json();
      render(data);
    } catch {
      // Silently fail — widget is non-critical
    }
  }

  // Re-poll every 60 seconds while the tab is visible
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') load();
  });

  // Start/stop the 60s poll around navigations so it doesn't fire on other pages.
  // astro:page-load fires on initial load AND after every View Transition.
  let pollId: ReturnType<typeof setInterval> | null = null;

  document.addEventListener('astro:before-swap', () => {
    if (pollId !== null) { clearInterval(pollId); pollId = null; }
  });

  document.addEventListener('astro:page-load', () => {
    load();
    if (pollId === null) pollId = setInterval(load, 60_000);
  });
</script>

<style>
  /* ── Skeleton ──────────────────────────────────────────────── */
  .np-skel {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .np-skel-art {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    background: var(--border);
    border-radius: 1px;
    animation: np-pulse 1.6s ease-in-out infinite;
  }

  .np-skel-lines {
    display: flex;
    flex-direction: column;
    gap: 0.35em;
  }

  .np-skel-line {
    height: 0.8em;
    background: var(--border);
    border-radius: 1px;
    animation: np-pulse 1.6s ease-in-out infinite;
  }

  .np-skel-line--title  { width: 9rem; }
  .np-skel-line--artist { width: 5.5rem; animation-delay: 0.2s; }

  @keyframes np-pulse {
    0%, 100% { opacity: 1;    }
    50%       { opacity: 0.4; }
  }

  @media (prefers-reduced-motion: reduce) {
    .np-skel-art,
    .np-skel-line { animation: none; }
  }

  /* .np-wrap is static HTML so scoped styles apply */
  .np-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Everything else is injected via innerHTML — must use :global() */
  :global(.np-idle) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-xs);
    color: var(--subtle);
  }

  :global(.np-cat) {
    width: 40px;
    height: 40px;
    object-fit: cover;
    flex-shrink: 0;
    border-radius: 1px;
  }

  :global(.np-flip) {
    display: inline-block;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    perspective: 400px;
    cursor: default;
  }

  :global(.np-flip-inner) {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 420ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  :global(.np-flip:hover .np-flip-inner) {
    transform: rotateY(180deg);
  }

  :global(.np-flip-front),
  :global(.np-flip-back) {
    display: block;
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  :global(.np-flip-back) {
    transform: rotateY(180deg);
  }

  :global(.np-wave) {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 20px;
    flex-shrink: 0;
    margin-left: 0.75rem;
  }

  :global(.np-bar) {
    width: 3px;
    border-radius: 1.5px;
    background: var(--subtle);
    height: 20px;
    transform: scaleY(0.2);
    transform-origin: bottom;
  }

  :global(.np-wave--live .np-bar) {
    background: var(--muted);
    animation: soundwave 1.4s ease-in-out infinite;
  }

  :global(.np-wave--live .np-bar:nth-child(1)) { animation-duration: 1.1s; animation-delay: -0.3s; }
  :global(.np-wave--live .np-bar:nth-child(2)) { animation-duration: 0.8s; animation-delay: -0.7s; }
  :global(.np-wave--live .np-bar:nth-child(3)) { animation-duration: 1.4s; animation-delay: -0.1s; }
  :global(.np-wave--live .np-bar:nth-child(4)) { animation-duration: 1.0s; animation-delay: -0.5s; }

  @keyframes soundwave {
    0%   { transform: scaleY(0.2);  }
    20%  { transform: scaleY(1);    }
    40%  { transform: scaleY(0.35); }
    60%  { transform: scaleY(0.85); }
    80%  { transform: scaleY(0.25); }
    100% { transform: scaleY(0.2);  }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.np-wave--live .np-bar) {
      animation: none;
      transform: scaleY(0.7);
    }
  }

  :global(.np-art) {
    width: 40px;
    height: 40px;
    object-fit: cover;
    flex-shrink: 0;
    display: block;
  }

  :global(.np-flip-front .np-art) {
    filter: saturate(0.7);
    transition: filter 250ms;
  }

  :global(.np-flip:hover .np-flip-front .np-art) {
    filter: saturate(1);
  }

  :global(.np-art-cat) {
    filter: none;
    background-color: var(--bg);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.np-flip-inner) {
      transition: none;
    }
  }

  :global(.np-track) {
    display: flex;
    flex-direction: column;
    gap: 0.1em;
    text-decoration: none;
    min-width: 0;
    line-height: 1.3;
  }

  :global(.np-title) {
    font-size: var(--text-base);
    color: var(--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.np-track) {
    transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  :global(a.np-track:hover) {
    transform: translateX(4px);
  }

  :global(.np-artist) {
    font-size: var(--text-xs);
    color: var(--subtle);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: 0.02em;
  }
</style>
