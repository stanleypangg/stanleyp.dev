---
// WaveViz.astro — Ambient frequency-bar visualization above the footer.
// Canvas 2D, generative sine composition. Reacts to playback state via DOM observation.
// Shows a ⏸ icon when music is paused (home page only). Pauses RAF off-screen.
---

<div id="wave-wrap" class="wave-wrap" data-paused="false" transition:persist>
  <canvas
    id="wave-viz"
    class="wave-viz"
    aria-hidden="true"
    role="presentation"
  ></canvas>
</div>

<style>
  .wave-wrap {
    position: relative;
    margin-top: 1rem;
    height: 52px;       /* keep layout footprint stable */
    overflow: visible;  /* allow bars to poke above */
  }

  .wave-viz {
    display: block;
    width: 100%;
    height: calc(52px + 40px); /* 40px overflow headroom above */
    margin-top: -40px;         /* shift up; floor stays at wrap bottom */
  }

  @media (hover: hover) {
    .wave-viz { cursor: crosshair; }
  }

</style>

<script>
  let _cleanup: (() => void) | null = null;
  let _initialized = false;
  let _updatePage: (() => void) | null = null;

  function initWaveViz() {
    // Already running — just update page context (npPresent / playTarget)
    if (_initialized && _updatePage) {
      _updatePage();
      return;
    }
    _initialized = true;

    const wrap   = document.getElementById('wave-wrap')  as HTMLDivElement      | null;
    const canvas = document.getElementById('wave-viz')   as HTMLCanvasElement   | null;
    if (!canvas || !wrap) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // ── Constants ───────────────────────────────────────────────
    const PITCH       = 6;     // px per column (bar + gap)
    const BAR_W       = 2;     // bar width px
    const MIN_H       = 3;     // minimum bar height px
    const HOVER_RATE  = 0.08;  // lerp speed: hover color
    const PLAY_RATE   = 0.018; // lerp speed: playing ↔ paused (slow, graceful)
    const OVERFLOW_H  = 40;    // px of canvas headroom above the visible zone

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Is NowPlaying present on this page? Mutable — updated on navigation.
    // On other pages (projects, writing…) we use a neutral ambient level.
    let npPresent = !!document.getElementById('np-wrap');

    let logW = 0, logH = 0;
    let rafId = 0;
    let startTs: number | null = null;
    let visible = true;
    let hoverLerp   = 0;
    let hoverTarget = 0;
    let playLerp    = npPresent ? 0 : 0.55; // start at ambient on non-home pages
    let playTarget  = npPresent ? 0 : 0.55;

    // Called on each navigation to update page context without restarting the loop.
    // Also forces recovery from stale observer state caused by the persist detach/reattach cycle.
    _updatePage = () => {
      const wasHome = npPresent;
      npPresent = !!document.getElementById('np-wrap');
      if (wasHome && !npPresent) playTarget = 0.55; // ambient when leaving home

      // IntersectionObserver or ResizeObserver may have fired with stale state
      // (isIntersecting=false, size=0) during the brief detach. Reset explicitly.
      visible = true;
      setup();
      if (!reducedMotion && rafId === 0) {
        startTs = null;
        rafId = requestAnimationFrame(tick);
      }
    };

    // ── Cursor displacement ──────────────────────────────────────
    let cursorX    = -1;    // mouse X in CSS px from canvas left; -1 = off-canvas
    let cursorLerp = 0;     // smoothed cursor position
    let cursorAmp  = 0;     // 0→1: fades in on mouseenter, out on mouseleave
    const CURSOR_RADIUS   = 60;    // px: gaussian influence half-width
    const CURSOR_STRENGTH = 0.35;  // max upward displacement as fraction of logH
    const CURSOR_FADE     = 0.10;  // lerp rate for enter/exit fade

    // ── Click ripple pool (pre-allocated, no hot-path allocs) ────
    let prevT = 0;
    const MAX_RIPPLES = 6;
    const ripples: Array<{ x: number; t: number; amp: number; alive: boolean }> = [];
    for (let r = 0; r < MAX_RIPPLES; r++) ripples.push({ x: 0, t: 0, amp: 0, alive: false });
    const RIPPLE_SPEED    = 120;   // px/sec radial travel
    const RIPPLE_DECAY    = 2.2;   // sec to e^-1 amplitude decay
    const RIPPLE_STRENGTH = 0.25;  // max displacement as fraction of logH
    const RIPPLE_WIDTH    = 30;    // px: gaussian envelope width around wavefront

    // ── Canvas setup ────────────────────────────────────────────
    function setup() {
      const dpr  = window.devicePixelRatio || 1;
      const rect = canvas!.getBoundingClientRect();
      logW = rect.width;
      logH = rect.height;
      canvas!.width  = Math.round(logW * dpr);
      canvas!.height = Math.round(logH * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    // ── Bar color ────────────────────────────────────────────────
    // Lightens toward --subtle on hover; brightens (more contrast) when playing.
    function barColor(): string {
      const dark = document.documentElement.classList.contains('dark');
      if (dark) {
        const lBase  = 35 + 18 * playLerp;   // 35% paused → 53% playing
        const lFinal = lBase + 15 * hoverLerp;
        return `oklch(${lFinal.toFixed(1)}% 0.003 260)`;
      } else {
        const lBase  = 87 - 13 * playLerp;   // 87% paused → 74% playing
        const lFinal = lBase - 13 * hoverLerp;
        return `oklch(${lFinal.toFixed(1)}% 0.003 80)`;
      }
    }

    // ── Draw one frame ──────────────────────────────────────────
    function draw(t: number) {
      ctx!.clearRect(0, 0, logW, logH);
      ctx!.fillStyle = barColor();

      // Amplitude: wide contrast between paused (0.2) and playing (1.0)
      // so the state change is unmistakable.
      const amp = 0.20 + 0.80 * playLerp;

      // visH is the visible 52px zone; logH includes the overflow headroom above.
      // All amplitude math uses visH so behaviour is unchanged vs. before.
      const visH  = logH - OVERFLOW_H;

      const N     = Math.floor(logW / PITCH);
      const sigma = CURSOR_RADIUS / 2.5; // gaussian std-dev for cursor bulge
      for (let i = 0; i < N; i++) {
        const xn   = i / N;
        const barX = i * PITCH;

        const wave =
          amp * (
            1.00 * Math.sin(t * 1.88 + xn * 9.42) +
            0.35 * Math.sin(t * 1.19 + xn * 18.85 + 1.5) +
            0.20 * Math.sin(t * 3.20 + xn * 28.27 + 0.8)
          );
        // wave range: approx [-1.55·amp, 1.55·amp]; normalise to [0, 1]
        const norm = (wave + 1.55) / 3.1;
        let h = MIN_H + (visH - MIN_H) * Math.max(0, Math.min(1, norm));

        // ── Cursor proximity bulge ───────────────────────────────
        if (cursorAmp > 0.001) {
          const dx    = barX - cursorLerp;
          const gauss = Math.exp(-(dx * dx) / (2 * sigma * sigma));
          h += cursorAmp * gauss * CURSOR_STRENGTH * visH;
        }

        // ── Click ripple displacement ────────────────────────────
        for (let r = 0; r < MAX_RIPPLES; r++) {
          const rip = ripples[r];
          if (!rip.alive) continue;
          const dist      = Math.abs(barX - rip.x);
          const wavefront = rip.t * RIPPLE_SPEED;
          const offset    = dist - wavefront;
          const env       = Math.exp(-(offset * offset) / (2 * RIPPLE_WIDTH * RIPPLE_WIDTH));
          const osc       = Math.cos(offset * 0.15);
          h += rip.amp * env * osc * RIPPLE_STRENGTH * visH;
        }

        // Allow h to grow into overflow headroom; clamp at full canvas height.
        h = Math.max(MIN_H, Math.min(logH, h));
        ctx!.fillRect(barX, logH - h, BAR_W, h);
      }
    }

    // ── Animation loop ──────────────────────────────────────────
    function tick(ts: number) {
      if (startTs === null) startTs = ts;
      const t = (ts - startTs) / 1000;

      // Advance lerps
      hoverLerp += (hoverTarget - hoverLerp) * HOVER_RATE;
      playLerp  += (playTarget  - playLerp)  * PLAY_RATE;

      // Advance cursor displacement state
      const dt = startTs === null ? 0 : t - prevT;
      prevT = t;
      if (cursorX >= 0) cursorLerp = cursorX;
      const cursorOn = hoverTarget === 1 ? 1 : 0;
      cursorAmp += (cursorOn - cursorAmp) * CURSOR_FADE;

      // Age ripples
      for (let r = 0; r < MAX_RIPPLES; r++) {
        const rip = ripples[r];
        if (!rip.alive) continue;
        rip.t  += dt;
        rip.amp = Math.exp(-rip.t / RIPPLE_DECAY);
        if (rip.amp < 0.005) rip.alive = false;
      }

      // Detect playing state — zero coupling with NowPlaying component
      if (npPresent) {
        playTarget = document.querySelector('.np-wave--live') ? 1 : 0;
        wrap!.dataset.paused = String(playTarget === 0);
      }
      // On other pages: playTarget stays at 0.55 (ambient), no pause icon ever shown.

      draw(t);

      if (visible) {
        rafId = requestAnimationFrame(tick);
      } else {
        rafId = 0;
      }
    }

    // ── Init ────────────────────────────────────────────────────
    setup();

    if (reducedMotion) {
      draw(0);
    } else {
      rafId = requestAnimationFrame(tick);
    }

    // Hover brightening + cursor tracking
    canvas.addEventListener('mouseenter', () => { hoverTarget = 1; });
    canvas.addEventListener('mouseleave', () => { hoverTarget = 0; cursorX = -1; });

    if (!reducedMotion) {
      canvas.addEventListener('mousemove', (e: MouseEvent) => {
        cursorX = e.clientX - canvas!.getBoundingClientRect().left;
      }, { passive: true });

      canvas.addEventListener('click', (e: MouseEvent) => {
        const clickX = e.clientX - canvas!.getBoundingClientRect().left;
        // Find first dead slot
        for (let r = 0; r < MAX_RIPPLES; r++) {
          if (!ripples[r].alive) {
            ripples[r].x = clickX; ripples[r].t = 0; ripples[r].amp = 1; ripples[r].alive = true;
            return;
          }
        }
        // All slots full — overwrite lowest-amplitude ripple
        let minIdx = 0;
        for (let r = 1; r < MAX_RIPPLES; r++) {
          if (ripples[r].amp < ripples[minIdx].amp) minIdx = r;
        }
        ripples[minIdx].x = clickX; ripples[minIdx].t = 0; ripples[minIdx].amp = 1; ripples[minIdx].alive = true;
      });
    }

    // Pause RAF when scrolled off-screen
    const io = new IntersectionObserver(([entry]) => {
      visible = entry.isIntersecting;
      if (visible && !reducedMotion && rafId === 0) {
        startTs = null;
        rafId = requestAnimationFrame(tick);
      }
    });
    io.observe(canvas);

    // Resize
    const ro = new ResizeObserver(() => {
      cancelAnimationFrame(rafId);
      rafId = 0;
      setup();
      if (reducedMotion) {
        draw(0);
      } else {
        startTs = null;
        rafId = requestAnimationFrame(tick);
      }
    });
    ro.observe(canvas);

    function cleanup() {
      cancelAnimationFrame(rafId);
      io.disconnect();
      ro.disconnect();
    }

    _cleanup = cleanup;
  }

  document.addEventListener('astro:page-load', initWaveViz);
</script>
