---
import { ViewTransitions } from 'astro:transitions';
import ThemeToggle from '../components/ThemeToggle.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Portfolio',
  description = 'Software engineer.',
} = Astro.props;

const pathname = Astro.url.pathname;
const lastUpdated = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
const isProjects = pathname.startsWith('/projects');
const isWriting  = pathname.startsWith('/writing');
const isMusic    = pathname.startsWith('/music');
const isPictures = pathname.startsWith('/pictures');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/logo.png" />

    <!-- Google Fonts: Fraunces (display) + DM Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300&family=DM+Sans:opsz,wght@9..40,300;9..40,400&display=swap"
      rel="stylesheet"
    />

    <!-- Prevent flash of wrong theme — must be inline and synchronous -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <ViewTransitions />

    <!-- Console easter egg — for engineers who inspect -->
    <script is:inline>
      if (!window.__greeted) {
        window.__greeted = true;
        console.log(
          '%cStanley Pang\n%cBuilt with Astro · Inspecting the source? Good instinct.',
          'font-family: Georgia, serif; font-size: 1.1em; font-weight: 400;',
          'font-family: system-ui, sans-serif; font-size: 0.8em; font-weight: 300; color: #888;'
        );
      }
    </script>
  </head>

  <body>
    <div class="wrap">
      <nav class="site-nav">
        <div class="nav-inner">
          <a href="/" class="nav-home" aria-label="Home">
            <img src="/logo.png" alt="" class="nav-logo" width="28" height="28" />
          </a>
          <ul class="nav-links">
            <li>
              <a
                href="/projects"
                class="nav-link"
                aria-current={isProjects ? 'page' : undefined}
              >projects</a>
            </li>
            <li>
              <a
                href="/writing"
                class="nav-link"
                aria-current={isWriting ? 'page' : undefined}
              >writing</a>
            </li>
            <li>
              <a
                href="/music"
                class="nav-link"
                aria-current={isMusic ? 'page' : undefined}
              >music</a>
            </li>
            <li>
              <a
                href="/pictures"
                class="nav-link"
                aria-current={isPictures ? 'page' : undefined}
              >pictures</a>
            </li>
            <li>
              <ThemeToggle />
            </li>
          </ul>
        </div>
      </nav>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <ul class="footer-links">
          <li><a href="#" class="elsewhere-link">GitHub</a></li>
          <li><a href="#" class="elsewhere-link">LinkedIn</a></li>
          <li><a href="#" class="elsewhere-link">Email</a></li>
          <li><a href="https://x.com/stanleypangg" target="_blank" rel="noopener noreferrer" class="elsewhere-link">X</a></li>
        </ul>
        <span class="footer-updated">Updated {lastUpdated}</span>
      </footer>
    </div>
  </body>
</html>
