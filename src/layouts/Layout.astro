---
import { ClientRouter } from 'astro:transitions';
import ThemeToggle from '../components/ThemeToggle.astro';
import WaveViz from '../components/WaveViz.astro';
import CursorEffect from '../components/CursorEffect.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'Stanley Pang',
  description = 'Software engineer.',
  ogType = 'website',
  ogImage = '/og.png',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site).toString();
const pageTitle = title === 'Stanley Pang' ? title : `${title} — Stanley Pang`;

const pathname = Astro.url.pathname;
const lastUpdated = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
const isHome     = pathname === '/';
const isProjects = pathname.startsWith('/projects');
const isWriting  = pathname.startsWith('/writing');
const isMusic    = pathname.startsWith('/music');
const isPictures = pathname.startsWith('/pictures');
const isChat     = pathname.startsWith('/chat');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/logo.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="oklch(97% 0.005 80)" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="oklch(12% 0 0)" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Stanley Pang" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@stanleypangg" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Google Fonts: Fraunces (display) + DM Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Spotify album art CDN — used by NowPlaying on home page and music page -->
    <link rel="preconnect" href="https://i.scdn.co" crossorigin />
    {isMusic && <link rel="preconnect" href="https://lastfm.freetls.fastly.net" crossorigin />}
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300&family=DM+Sans:opsz,wght@9..40,300..400&display=swap"
      onload="this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300&family=DM+Sans:opsz,wght@9..40,300..400&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Prevent flash of wrong theme — must be inline and synchronous -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!--
      Override the native View Transitions API before ClientRouter loads.
      The ::view-transition top layer renders above EVERYTHING — including
      z-index and the CSS top layer — so there is no CSS trick to keep the
      custom cursor visible and free during a native VT. Instead we replace
      startViewTransition with a manual <main> fade that never hides the cursor.
    -->
    <script is:inline>
      (function () {
        if (!('startViewTransition' in document)) return;

        var OUT = 160;
        var IN  = 320;
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        document.startViewTransition = function (callback) {
          var oldMain = document.querySelector('main');

          if (!reduce && oldMain) {
            oldMain.style.transition = 'opacity ' + OUT + 'ms ease-in';
            oldMain.style.opacity = '0';
          }

          // updateCallbackDone: resolves after DOM swap (Astro uses this for ready)
          var updateCallbackDone = (reduce
            ? Promise.resolve().then(callback)
            : new Promise(function (res) { setTimeout(res, OUT); }).then(callback)
          );

          // finished: resolves after enter animation completes
          var finished = updateCallbackDone.then(function () {
            var newMain = document.querySelector('main');
            if (!reduce && newMain) {
              newMain.style.opacity = '0';
              newMain.style.transition = 'none';
              void newMain.offsetHeight;
              newMain.style.transition = 'opacity ' + IN + 'ms cubic-bezier(0.16,1,0.3,1)';
              newMain.style.opacity = '1';
              return new Promise(function (res) { setTimeout(res, IN); }).then(function () {
                newMain.style.transition = '';
                newMain.style.opacity = '';
              });
            }
          });

          return { ready: updateCallbackDone, finished: finished, updateCallbackDone: updateCallbackDone };
        };
      })();
    </script>

    <ClientRouter />

    <!-- Console easter egg — for engineers who inspect -->
    <script is:inline>
      (function () {
        try {
          if (sessionStorage.getItem('__greeted')) return;
          sessionStorage.setItem('__greeted', '1');
        } catch { return; }
        console.log(
          '%cStanley Pang\n%cBuilt with Astro · Inspecting the source? Good instinct.',
          'font-family: Georgia, serif; font-size: 1.1em; font-weight: 400;',
          'font-family: system-ui, sans-serif; font-size: 0.8em; font-weight: 300; color: #888;'
        );
      })();
    </script>
  </head>

  <body>
    <CursorEffect />
    <canvas id="bg-dots" aria-hidden="true"></canvas>
    <div class="wrap">
      <nav class="site-nav" aria-label="Site navigation">
        <div class="nav-inner">
          <a href="/" class="nav-home" aria-label="Home" aria-current={isHome ? 'page' : undefined}>
            <img src="/logo.png" alt="" class="nav-logo" width="28" height="28" />
          </a>
          <ul class="nav-links">
            <li>
              <a
                href="/projects"
                class="nav-link"
                aria-current={isProjects ? 'page' : undefined}
              >projects</a>
            </li>
            <li>
              <a
                href="/writing"
                class="nav-link"
                aria-current={isWriting ? 'page' : undefined}
              >writing</a>
            </li>
            <li>
              <a
                href="/music"
                class="nav-link"
                data-astro-prefetch="hover"
                aria-current={isMusic ? 'page' : undefined}
              >music</a>
            </li>
            <li>
              <a
                href="/pictures"
                class="nav-link"
                data-astro-prefetch="hover"
                aria-current={isPictures ? 'page' : undefined}
              >pictures</a>
            </li>
            <li>
              <a
                href="/chat"
                class="nav-link"
                data-astro-prefetch="hover"
                aria-current={isChat ? 'page' : undefined}
              >chat</a>
            </li>
          </ul>
          <ThemeToggle />
        </div>
      </nav>

      <main>
        <slot />
      </main>

      <WaveViz />

      <footer class="site-footer" transition:persist>
        <span class="footer-updated">Updated {lastUpdated}</span>
        <span class="footer-visitors" aria-live="polite">
          <span class="eye-icon" aria-hidden="true"></span>
          <span id="visitor-count">—</span>
        </span>
      </footer>
    </div>
  </body>


<script>
  // ── Dot-grid canvas with cursor attraction ───────────────────────────
  // View Transitions swap the <body>, so the canvas element is replaced
  // on each navigation. We re-grab it via astro:after-swap while keeping
  // mouse listeners and RAF state at module scope (added only once).

  const SPACING  = 28;
  const DOT_R    = 1;
  const RADIUS   = 140;
  const STRENGTH = 0.55;
  const SPRING_K = 0.12;
  const DAMPING  = 0.75;
  const IDLE_EPS = 0.01;

  type Dot = { hx: number; hy: number; x: number; y: number; vx: number; vy: number };

  let canvas: HTMLCanvasElement | null = null;
  let ctx: CanvasRenderingContext2D | null = null;
  let dots: Dot[] = [];
  let mouse = { x: -9999, y: -9999 };
  let rafId = 0;
  let rafRunning = false;
  let resizeRaf = 0;
  let dotColor = '';

  const prefersReducedMotion =
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function readColor() {
    dotColor = getComputedStyle(document.documentElement)
      .getPropertyValue('--dot').trim();
  }

  function buildGrid() {
    if (!canvas) return;
    dots = [];
    const ox = SPACING / 2;
    const oy = SPACING / 2;
    const cols = Math.ceil(canvas.width  / SPACING) + 2;
    const rows = Math.ceil(canvas.height / SPACING) + 2;
    for (let r = -1; r < rows; r++) {
      for (let c = -1; c < cols; c++) {
        const hx = ox + c * SPACING;
        const hy = oy + r * SPACING;
        dots.push({ hx, hy, x: hx, y: hy, vx: 0, vy: 0 });
      }
    }
  }

  function draw() {
    if (!canvas || !ctx) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = dotColor;
    ctx.beginPath();
    for (const d of dots) {
      ctx.moveTo(d.x + DOT_R, d.y);
      ctx.arc(d.x, d.y, DOT_R, 0, Math.PI * 2);
    }
    ctx.fill();
  }

  function tick() {
    let anyActive = mouse.x > -1000;

    for (const d of dots) {
      const dx = mouse.x - d.hx;
      const dy = mouse.y - d.hy;
      const dist = Math.sqrt(dx * dx + dy * dy);

      let tx = d.hx, ty = d.hy;
      if (dist > 0 && dist < RADIUS) {
        const falloff = 1 - dist / RADIUS;
        tx = d.hx + dx * STRENGTH * falloff;
        ty = d.hy + dy * STRENGTH * falloff;
      }

      d.vx = (d.vx + (tx - d.x) * SPRING_K) * DAMPING;
      d.vy = (d.vy + (ty - d.y) * SPRING_K) * DAMPING;
      d.x += d.vx;
      d.y += d.vy;

      if (!anyActive && (
        Math.abs(d.vx) > IDLE_EPS || Math.abs(d.vy) > IDLE_EPS ||
        Math.abs(d.x - d.hx) > IDLE_EPS || Math.abs(d.y - d.hy) > IDLE_EPS
      )) anyActive = true;
    }

    draw();

    if (anyActive) {
      rafId = requestAnimationFrame(tick);
    } else {
      rafRunning = false;
    }
  }

  function startTick() {
    if (!rafRunning) {
      rafRunning = true;
      rafId = requestAnimationFrame(tick);
    }
  }

  function resize() {
    if (!canvas) return;
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    buildGrid();
    if (!rafRunning) draw();
  }

  // Called on first load AND after every View Transition swap
  function attachCanvas() {
    cancelAnimationFrame(rafId);
    rafRunning = false;

    canvas = document.getElementById('bg-dots') as HTMLCanvasElement | null;
    if (!canvas) return;
    ctx = canvas.getContext('2d');

    readColor();
    resize();

    // Restart animation if cursor is already on the page
    if (!prefersReducedMotion && mouse.x > -1000) startTick();
  }

  // Global listeners — added once, persist across View Transitions
  window.addEventListener('resize', () => {
    cancelAnimationFrame(resizeRaf);
    resizeRaf = requestAnimationFrame(resize);
  }, { passive: true });

  new MutationObserver(() => {
    readColor();
    if (!rafRunning) draw();
  }).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  });

  if (!prefersReducedMotion) {
    document.addEventListener('mousemove', (e: MouseEvent) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
      startTick();
    }, { passive: true });

    document.addEventListener('mouseleave', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });
  }

  // Bootstrap
  attachCanvas();
  document.addEventListener('astro:after-swap', attachCanvas);

  // ── Visitor counter ───────────────────────────────────────
  const VISITORS_KEY = 'visitor-count-cache';

  async function trackAndShowVisitors() {
    const el = document.getElementById('visitor-count');
    if (!el) return;
    const cached = localStorage.getItem(VISITORS_KEY);
    if (cached) el.textContent = Number(cached).toLocaleString();
    fetch('/api/views', { method: 'POST' }).catch(() => {});
    try {
      const res = await fetch('/api/views');
      if (res.ok) {
        const { count } = await res.json();
        el.textContent = count.toLocaleString();
        localStorage.setItem(VISITORS_KEY, String(count));
      }
    } catch { /* silently fail */ }
  }

  trackAndShowVisitors();
  document.addEventListener('astro:after-swap', trackAndShowVisitors);
</script>
</html>
