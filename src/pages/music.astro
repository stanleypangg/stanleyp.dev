---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { getTopArtists, getTopAlbums, getTopTracks, getRecentTracks } from '../lib/lastfm';
import { esc, formatPlaycount, formatTimestamp } from '../lib/music-utils';

const lfmUser = import.meta.env.PUBLIC_LASTFM_USERNAME;
const lfmKey  = import.meta.env.PUBLIC_LASTFM_API_KEY;

// Fetch all default (7-day) data in parallel on the server
const [artistsRes, albumsRes, topTracksRes, recentTracksRes] = await Promise.allSettled([
  getTopArtists('7day', 10, lfmKey, lfmUser),
  getTopAlbums('7day', 10, lfmKey, lfmUser),
  getTopTracks('7day', 10, lfmKey, lfmUser),
  getRecentTracks(10, lfmKey, lfmUser),
]);

const artists     = artistsRes.status     === 'fulfilled' ? artistsRes.value     : [];
const albums      = albumsRes.status      === 'fulfilled' ? albumsRes.value      : [];
const topTracks   = topTracksRes.status   === 'fulfilled' ? topTracksRes.value   : [];
const recentTracks = recentTracksRes.status === 'fulfilled' ? recentTracksRes.value : [];

// Resolve artist images server-side via the CDN-cached /api/artist-images endpoint.
// This eliminates the client-side waterfall — images arrive in the initial HTML.
// The API has s-maxage=3600 (1hr), so most SSR invocations hit a warm CDN cache.
type ArtistImageMap = Record<string, { imageUrl: string | null; spotifyUrl: string | null }>;
let artistImages: ArtistImageMap = {};
if (artists.length > 0) {
  try {
    const params = new URLSearchParams(artists.map((a) => ['names', a.name]));
    const res = await fetch(`${import.meta.env.SITE}/api/artist-images?${params}`);
    if (res.ok) artistImages = await res.json() as ArtistImageMap;
  } catch { /* non-critical — client will retry */ }
}

// Cache at the Vercel edge for 5 min; browser for 1 min; serve stale up to 10 more min while revalidating
Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=300, stale-while-revalidate=600');
---

<Layout title="Listening — Stanley Pang" description="Music I've been listening to.">
  <header class="page-header">
    <h1 class="page-title">Listening history</h1>
    <a
      class="lfm-link"
      href={`https://www.last.fm/user/${lfmUser}`}
      target="_blank"
      rel="noopener noreferrer"
    >last.fm ↗</a>
  </header>

  <div class="controls-spacer"></div>

  <!-- Controls: period + view toggle -->
  <div class="toggle controls-row" role="group" aria-label="Controls">
    <div class="period-group" role="group" aria-label="Time period">
      <button class="toggle-btn active" data-period="7day">7d</button>
      <button class="toggle-btn" data-period="1month">1m</button>
      <button class="toggle-btn" data-period="12month">1y</button>
      <button class="toggle-btn" data-period="overall">all time</button>
    </div>
    <div class="view-group" role="group" aria-label="View mode">
      <button class="toggle-btn active" data-view="grid">grid</button>
      <button class="toggle-btn" data-view="chart">chart</button>
    </div>
  </div>

  <hr class="rule" />

  <!-- Top Artists -->
  <section id="section-artists">
    <span class="label">Top artists</span>
    <div class="grid" id="artists-grid">
      {artists.length > 0 ? artists.map((a, i) => {
        const data = artistImages[a.name];
        const href = data?.spotifyUrl ?? a.url;
        const imgEl = data?.imageUrl
          ? `<img src="${esc(data.imageUrl)}" alt="${esc(a.name)}" width="300" height="300" loading="${i < 3 ? 'eager' : 'lazy'}" decoding="${i < 3 ? 'auto' : 'async'}" fetchpriority="${i < 3 ? 'high' : 'auto'}" class="img-loaded" />`
          : `<div class="img-placeholder" aria-hidden="true"></div>`;
        return <div class="grid-item" set:html={`<a href="${esc(href)}" target="_blank" rel="noopener noreferrer">${imgEl}<div class="item-overlay"><span class="item-name">${esc(a.name)}</span><span class="item-meta">${formatPlaycount(a.playcount)}</span></div></a>`} />;
      }) : Array.from({ length: 10 }).map(() => <div class="grid-item skeleton" />)}
    </div>
  </section>

  <hr class="rule" />

  <!-- Top Albums -->
  <section id="section-albums">
    <span class="label">Top albums</span>
    <div class="grid" id="albums-grid">
      {albums.length > 0 ? albums.map((a, i) => {
        const imgEl = a.imageUrl
          ? `<img src="${esc(a.imageUrl)}" alt="${esc(a.name)}" width="300" height="300" loading="${i < 5 ? 'eager' : 'lazy'}" decoding="${i < 5 ? 'auto' : 'async'}" fetchpriority="${i < 5 ? 'high' : 'auto'}" class="img-loaded" />`
          : `<div class="img-placeholder" aria-hidden="true"></div>`;
        return <div class="grid-item" set:html={`<a href="${esc(a.url)}" target="_blank" rel="noopener noreferrer">${imgEl}<div class="item-overlay"><span class="item-name">${esc(a.name)}</span><span class="item-meta">${esc(a.artist)} · ${formatPlaycount(a.playcount)}</span></div></a>`} />;
      }) : Array.from({ length: 10 }).map(() => <div class="grid-item skeleton" />)}
    </div>
  </section>

  <hr class="rule" />

  <!-- Top Tracks -->
  <section id="section-top-tracks">
    <span class="label">Top tracks</span>
    <div class="track-list" id="top-tracks-list">
      {topTracks.length > 0 ? topTracks.map((t, i) => (
        <div class="entry entry--ranked" set:html={`<span class="entry-rank" aria-hidden="true">${String(i + 1).padStart(2, '0')}</span><span class="entry-title"><a href="${esc(t.url)}" target="_blank" rel="noopener noreferrer" class="link">${esc(t.name)}</a><span class="entry-sub"> · ${esc(t.artist)}</span></span><span class="entry-meta">${formatPlaycount(t.playcount)}</span>`} />
      )) : Array.from({ length: 10 }).map(() => <div class="entry skeleton-row" />)}
    </div>
  </section>

  <hr class="rule" />

  <!-- Recent Tracks -->
  <section id="section-tracks">
    <span class="label">Recent tracks</span>
    <div class="track-list" id="track-list">
      {recentTracks.length > 0 ? recentTracks.map((t) => {
        const isNow = t.timestamp === null;
        const metaEl = isNow
          ? `<span class="track-live-wave" aria-label="Now playing"><span class="track-live-bar"></span><span class="track-live-bar"></span><span class="track-live-bar"></span><span class="track-live-bar"></span></span>`
          : `<span class="entry-meta">${formatTimestamp(t.timestamp)}</span>`;
        return <div class="entry" set:html={`<span class="entry-title"><a href="${esc(t.url)}" target="_blank" rel="noopener noreferrer" class="link">${esc(t.name)}</a><span class="entry-sub"> · ${esc(t.artist)}</span></span>${metaEl}`} />;
      }) : Array.from({ length: 10 }).map(() => <div class="entry skeleton-row" />)}
    </div>
  </section>

  <!-- SSR data island: client JS reads this to hydrate in-memory state without refetching -->
  {artists.length > 0 && (
    <script id="ssr-music-data" type="application/json" set:html={JSON.stringify({
      period: '7day',
      artists,
      albums,
      topTracks,
      recentTracks,
      artistImages,
    })} />
  )}

<script is:inline data-astro-rerun>
  // Restore last rendered HTML synchronously — runs before the deferred module
  // so cached content appears immediately on every navigation (no skeleton flash).
  (function () {
    try {
      var period = localStorage.getItem('music_last_period') || '7day';

      var artistsEl   = document.getElementById('artists-grid');
      var albumsEl    = document.getElementById('albums-grid');
      var topTracksEl = document.getElementById('top-tracks-list');
      var tracksEl    = document.getElementById('track-list');

      // SSR already rendered real content for 7day — don't overwrite with stale cache
      var ssrRendered = artistsEl && !artistsEl.querySelector('.skeleton');

      if (ssrRendered && period === '7day') {
        // Perfect match: SSR content is correct, nothing to restore
      } else if (ssrRendered && period !== '7day') {
        // User's preferred period differs — restore their cached HTML if available
        var artistsHtml   = localStorage.getItem('music_ui_artists_'   + period);
        var albumsHtml    = localStorage.getItem('music_ui_albums_'    + period);
        var topTracksHtml = localStorage.getItem('music_ui_toptracks_' + period);
        if (artistsHtml && albumsEl && topTracksEl) {
          artistsEl.innerHTML   = artistsHtml;
          albumsEl.innerHTML    = albumsHtml || '';
          topTracksEl.innerHTML = topTracksHtml || '';
          document.querySelectorAll('[data-period]').forEach(function (b) {
            b.classList.toggle('active', b.getAttribute('data-period') === period);
          });
        }
        // If no cached HTML for their period, keep SSR 7day — module script will fetch
      } else {
        // SSR failed (skeletons) — restore from localStorage as usual
        var artistsHtml   = localStorage.getItem('music_ui_artists_'   + period);
        var albumsHtml    = localStorage.getItem('music_ui_albums_'    + period);
        var topTracksHtml = localStorage.getItem('music_ui_toptracks_' + period);
        if (artistsEl   && artistsHtml)   artistsEl.innerHTML   = artistsHtml;
        if (albumsEl    && albumsHtml)     albumsEl.innerHTML    = albumsHtml;
        if (topTracksEl && topTracksHtml)  topTracksEl.innerHTML = topTracksHtml;
        if (period !== '7day') {
          document.querySelectorAll('[data-period]').forEach(function (b) {
            b.classList.toggle('active', b.getAttribute('data-period') === period);
          });
        }
      }

      // Recent tracks: only restore from cache if SSR didn't render them
      var tracksHtml = localStorage.getItem('music_ui_tracks');
      if (tracksEl && tracksHtml && tracksEl.querySelector('.skeleton-row')) {
        tracksEl.innerHTML = tracksHtml;
      }
    } catch (_) { /* localStorage unavailable */ }
  })();
</script>

<script>
  import { getTopArtists, getTopAlbums, getTopTracks, getRecentTracks } from '../lib/lastfm';
  import type { Period, ArtistStat, AlbumStat, TrackStat, Track } from '../lib/lastfm';
  import { esc, formatPlaycount, formatTimestamp } from '../lib/music-utils';

  const API_KEY = import.meta.env.PUBLIC_LASTFM_API_KEY;
  const USERNAME = import.meta.env.PUBLIC_LASTFM_USERNAME;

  // ── localStorage cache ────────────────────────────────────────────────────
  const TTL = {
    period:   60 * 60 * 1000,   // 1 hour  — artist/album stats change slowly
    tracks:    5 * 60 * 1000,   // 5 min   — recent tracks change frequently
  };

  interface CacheEntry<T> { data: T; ts: number }
  interface ArtistData { imageUrl: string | null; spotifyUrl: string | null; }

  interface PeriodData {
    artists:    ArtistStat[];
    albums:     AlbumStat[];
    images:     Record<string, ArtistData>;
    topTracks:  TrackStat[];
  }

  function cacheGet<T>(key: string, ttl: number): T | null {
    try {
      const raw = localStorage.getItem(key);
      if (!raw) return null;
      const { data, ts }: CacheEntry<T> = JSON.parse(raw);
      if (Date.now() - ts > ttl) return null;
      return data;
    } catch { return null; }
  }

  function cacheSet<T>(key: string, data: T): void {
    try {
      localStorage.setItem(key, JSON.stringify({ data, ts: Date.now() }));
    } catch { /* storage quota exceeded — ignore */ }
  }

  // ── Render helpers ────────────────────────────────────────────────────────
  function renderArtists(artists: ArtistStat[], images: Map<string, ArtistData>, animate = true) {
    const grid = document.getElementById('artists-grid')!;
    grid.classList.remove('chart-view');
    grid.innerHTML = artists.map((a, i) => {
      const data = images.get(a.name);
      const animStyle = animate ? `animation-delay:${i * 50}ms` : `animation:none`;
      const imgEl = data?.imageUrl
        ? `<img src="${esc(data.imageUrl)}" alt="${esc(a.name)}" loading="lazy" decoding="async" style="${animStyle}" />`
        : `<div class="img-placeholder" aria-hidden="true" style="${animStyle}"></div>`;
      const href = data?.spotifyUrl ?? a.url;
      return `
        <div class="grid-item">
          <a href="${esc(href)}" target="_blank" rel="noopener noreferrer">
            ${imgEl}
            <div class="item-overlay">
              <span class="item-name">${esc(a.name)}</span>
              <span class="item-meta">${formatPlaycount(a.playcount)}</span>
            </div>
          </a>
        </div>`;
    }).join('');
  }

  function renderAlbums(albums: AlbumStat[], animate = true) {
    const grid = document.getElementById('albums-grid')!;
    grid.classList.remove('chart-view');
    grid.innerHTML = albums.map((a, i) => {
      const animStyle = animate ? `animation-delay:${i * 50}ms` : `animation:none`;
      const imgEl = a.imageUrl
        ? `<img src="${esc(a.imageUrl)}" alt="${esc(a.name)}" loading="lazy" decoding="async" style="${animStyle}" />`
        : `<div class="img-placeholder" aria-hidden="true" style="${animStyle}"></div>`;
      return `
        <div class="grid-item">
          <a href="${esc(a.url)}" target="_blank" rel="noopener noreferrer">
            ${imgEl}
            <div class="item-overlay">
              <span class="item-name">${esc(a.name)}</span>
              <span class="item-meta">${esc(a.artist)} · ${formatPlaycount(a.playcount)}</span>
            </div>
          </a>
        </div>`;
    }).join('');
  }

  function animateBars(grid: HTMLElement) {
    // Double rAF: first ensures elements are in DOM, second ensures initial scaleY(0) is painted
    requestAnimationFrame(() => requestAnimationFrame(() => {
      grid.querySelectorAll<HTMLElement>('.vchart-bar').forEach((bar, i) => {
        bar.style.transitionDelay = `${i * 50}ms`;
        bar.style.transform = 'scaleY(1)';
      });
    }));
  }

  function renderArtistsChart(artists: ArtistStat[]) {
    const grid = document.getElementById('artists-grid')!;
    grid.classList.add('chart-view');
    const max = artists[0]?.playcount ?? 1;
    const images = new Map(Object.entries(lastImages));
    grid.innerHTML = `<div class="vchart">${artists.map((a) => {
      const pct = (a.playcount / max) * 100;
      const data = images.get(a.name);
      const imgEl = data?.imageUrl
        ? `<img src="${esc(data.imageUrl)}" alt="" width="44" height="44" loading="lazy" />`
        : `<div class="vchart-img-placeholder"></div>`;
      return `
        <div class="vchart-col">
          <span class="vchart-count">${a.playcount.toLocaleString()}</span>
          <div class="vchart-bar-area">
            <div class="vchart-bar" style="height:${pct}%"></div>
          </div>
          <div class="vchart-img">${imgEl}</div>
          <span class="vchart-name" title="${esc(a.name)}">${esc(a.name)}</span>
        </div>`;
    }).join('')}</div>`;
    animateBars(grid);
  }

  function renderAlbumsChart(albums: AlbumStat[]) {
    const grid = document.getElementById('albums-grid')!;
    grid.classList.add('chart-view');
    const max = albums[0]?.playcount ?? 1;
    grid.innerHTML = `<div class="vchart">${albums.map((a) => {
      const pct = (a.playcount / max) * 100;
      const imgEl = a.imageUrl
        ? `<img src="${esc(a.imageUrl)}" alt="" width="44" height="44" loading="lazy" />`
        : `<div class="vchart-img-placeholder"></div>`;
      return `
        <div class="vchart-col">
          <span class="vchart-count">${a.playcount.toLocaleString()}</span>
          <div class="vchart-bar-area">
            <div class="vchart-bar" style="height:${pct}%"></div>
          </div>
          <div class="vchart-img">${imgEl}</div>
          <span class="vchart-name" title="${esc(a.name)}">${esc(a.name)}</span>
        </div>`;
    }).join('')}</div>`;
    animateBars(grid);
  }

  function renderTracks(tracks: Track[]) {
    const list = document.getElementById('track-list')!;
    list.innerHTML = tracks.map((t) => {
      const isNow = t.timestamp === null;
      const metaEl = isNow
        ? `<span class="track-live-wave" aria-label="Now playing">
             <span class="track-live-bar"></span><span class="track-live-bar"></span>
             <span class="track-live-bar"></span><span class="track-live-bar"></span>
           </span>`
        : `<span class="entry-meta">${formatTimestamp(t.timestamp)}</span>`;
      return `
        <div class="entry">
          <span class="entry-title">
            <a href="${esc(t.url)}" target="_blank" rel="noopener noreferrer" class="link">${esc(t.name)}</a>
            <span class="entry-sub"> · ${esc(t.artist)}</span>
          </span>
          ${metaEl}
        </div>`;
    }).join('');
  }

  function renderTopTracks(tracks: TrackStat[]) {
    const list = document.getElementById('top-tracks-list')!;
    list.innerHTML = tracks.map((t, i) => `
      <div class="entry entry--ranked">
        <span class="entry-rank" aria-hidden="true">${String(i + 1).padStart(2, '0')}</span>
        <span class="entry-title">
          <a href="${esc(t.url)}" target="_blank" rel="noopener noreferrer" class="link">${esc(t.name)}</a>
          <span class="entry-sub"> · ${esc(t.artist)}</span>
        </span>
        <span class="entry-meta">${formatPlaycount(t.playcount)}</span>
      </div>`).join('');
  }

  function showError(sectionId: string) {
    const el = document.getElementById(sectionId);
    if (!el) return;
    const content = el.querySelector('[id$="-grid"], [id$="-list"]');
    if (content) content.innerHTML = '<p class="unavailable">unavailable</p>';
  }

  // ── HTML cache — persist rendered markup for instant restores ─────────────
  function saveGridHtml(type: 'artists' | 'albums', period: Period): void {
    try {
      const el = document.getElementById(`${type}-grid`);
      if (el) localStorage.setItem(`music_ui_${type}_${period}`, el.innerHTML);
    } catch { /* quota exceeded */ }
  }

  function saveTracksHtml(): void {
    try {
      const el = document.getElementById('track-list');
      if (el) localStorage.setItem('music_ui_tracks', el.innerHTML);
    } catch { /* quota exceeded */ }
  }

  function saveTopTracksHtml(period: Period): void {
    try {
      const el = document.getElementById('top-tracks-list');
      if (el) localStorage.setItem(`music_ui_toptracks_${period}`, el.innerHTML);
    } catch { /* quota exceeded */ }
  }

  // ── State — reset by init() on every navigation ───────────────────────────
  let currentPeriod: Period = '7day';
  let viewMode: 'grid' | 'chart' = 'grid';

  // Last successfully loaded data — used for instant re-render on view toggle
  let lastArtists:   ArtistStat[] = [];
  let lastImages:    Record<string, ArtistData> = {};
  let lastAlbums:    AlbumStat[]  = [];
  let lastTopTracks: TrackStat[]  = [];

  async function loadPeriodData(period: Period, forceRender = false) {
    // Serve from cache immediately if fresh
    const cacheKey = `music_period_v4_${period}`;
    const cached = cacheGet<PeriodData>(cacheKey, TTL.period);
    if (cached) {
      lastArtists   = cached.artists;
      lastImages    = cached.images;
      lastAlbums    = cached.albums;
      lastTopTracks = cached.topTracks ?? [];
      if (viewMode === 'chart') {
        renderArtistsChart(cached.artists);
        renderAlbumsChart(cached.albums);
      } else {
        // Skip re-render if the inline script already restored cached HTML into the DOM
        // (initial load only — period toggles always force a render).
        const artistsGrid = document.getElementById('artists-grid');
        const htmlAlreadyRestored = !forceRender && artistsGrid && !artistsGrid.querySelector('.skeleton');
        if (!htmlAlreadyRestored) {
          renderArtists(cached.artists, new Map(Object.entries(cached.images)), !forceRender);
          saveGridHtml('artists', period);
          renderAlbums(cached.albums, !forceRender);
          saveGridHtml('albums', period);
        }
        if (cached.topTracks) {
          renderTopTracks(cached.topTracks);
          saveTopTracksHtml(period);
        }
      }
      return;
    }

    const [artistsResult, albumsResult, topTracksResult] = await Promise.allSettled([
      getTopArtists(period, 10, API_KEY, USERNAME),
      getTopAlbums(period, 10, API_KEY, USERNAME),
      getTopTracks(period, 10, API_KEY, USERNAME),
    ]);

    // Albums have their own images from Last.fm — render immediately
    if (albumsResult.status === 'fulfilled') {
      lastAlbums = albumsResult.value;
      if (viewMode === 'chart') {
        renderAlbumsChart(albumsResult.value);
      } else {
        renderAlbums(albumsResult.value, !forceRender);
        saveGridHtml('albums', period);
      }
    } else {
      showError('section-albums');
    }

    if (topTracksResult.status === 'fulfilled') {
      lastTopTracks = topTracksResult.value;
      renderTopTracks(topTracksResult.value);
      saveTopTracksHtml(period);
    } else {
      showError('section-top-tracks');
    }

    if (artistsResult.status === 'fulfilled') {
      const artists = artistsResult.value;

      // One batched server-side call instead of 10 client→Spotify calls.
      // The server caches results at the CDN layer (s-maxage=3600).
      let images: Record<string, ArtistData> = {};
      try {
        const imgController = new AbortController();
        const imgTimeout = setTimeout(() => imgController.abort(), 10000);
        const params = new URLSearchParams(artists.map((a) => ['names', a.name]));
        const res = await fetch(`/api/artist-images?${params}`, { signal: imgController.signal });
        clearTimeout(imgTimeout);
        if (res.ok) images = await res.json() as Record<string, ArtistData>;
      } catch { /* images are non-critical */ }

      lastArtists = artists;
      lastImages  = images;

      if (viewMode === 'chart') {
        renderArtistsChart(artists);
      } else {
        renderArtists(artists, new Map(Object.entries(images)), !forceRender);
        saveGridHtml('artists', period);
      }

      if (albumsResult.status === 'fulfilled' && topTracksResult.status === 'fulfilled') {
        cacheSet<PeriodData>(cacheKey, { artists, albums: albumsResult.value, images, topTracks: topTracksResult.value });
      }
    } else {
      showError('section-artists');
    }
  }

  async function loadStaticData() {
    const cachedTracks = cacheGet<Track[]>('music_tracks', TTL.tracks);
    if (cachedTracks) {
      const trackList = document.getElementById('track-list');
      if (trackList && trackList.querySelector('.skeleton-row')) {
        renderTracks(cachedTracks);
        saveTracksHtml();
      }
      return;
    }

    await getRecentTracks(10, API_KEY, USERNAME)
      .then((tracks) => { renderTracks(tracks); saveTracksHtml(); cacheSet('music_tracks', tracks); })
      .catch(() => showError('section-tracks'));
  }

  // ── Init — runs on every navigation via astro:page-load ──────────────────
  // Module scripts are ES module singletons (only evaluated once), so all
  // event listener binding and data loading must happen inside this function
  // which is re-called by astro:page-load on every View Transition navigation.
  async function init() {
    // Reset per-navigation state
    currentPeriod = (() => {
      try { return (localStorage.getItem('music_last_period') as Period) || '7day'; } catch { return '7day'; }
    })();
    viewMode = 'grid';
    lastArtists   = [];
    lastImages    = {};
    lastAlbums    = [];
    lastTopTracks = [];

    // ── Period toggle ──────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('.toggle-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!btn.dataset.period) return;   // ignore view buttons
        const period = btn.dataset.period as Period;
        if (period === currentPeriod) return;
        currentPeriod = period;
        try { localStorage.setItem('music_last_period', period); } catch { /* ignore */ }

        document.querySelectorAll('[data-period]').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        await loadPeriodData(period, true);
      });
    });

    // ── View toggle ────────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('[data-view]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.view as 'grid' | 'chart';
        if (mode === viewMode) return;
        viewMode = mode;

        document.querySelectorAll('[data-view]').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        if (viewMode === 'chart') {
          renderArtistsChart(lastArtists);
          renderAlbumsChart(lastAlbums);
        } else {
          renderArtists(lastArtists, new Map(Object.entries(lastImages)));
          saveGridHtml('artists', currentPeriod);
          renderAlbums(lastAlbums);
          saveGridHtml('albums', currentPeriod);
        }
      });
    });

    // ── SSR data hydration ─────────────────────────────────────────────────
    // The server embeds a JSON island with the default 7day data. Read it once
    // to populate in-memory state and seed localStorage caches — no fetch needed.
    const ssrEl = document.getElementById('ssr-music-data');
    let ssrData: {
      period: string;
      artists: ArtistStat[];
      albums: AlbumStat[];
      topTracks: TrackStat[];
      recentTracks: Track[];
      artistImages?: Record<string, ArtistData>;
    } | null = null;
    if (ssrEl) {
      try { ssrData = JSON.parse(ssrEl.textContent ?? ''); } catch { /* malformed */ }
    }

    // Seed recent tracks cache from SSR data (images seeded after async fetch below)
    if (ssrData) {
      if (ssrData.recentTracks.length > 0 && !cacheGet('music_tracks', TTL.tracks)) {
        cacheSet('music_tracks', ssrData.recentTracks);
      }
    }

    // ── Load data ──────────────────────────────────────────────────────────
    if (ssrData && currentPeriod === ssrData.period) {
      // SSR rendered the correct period — populate state from data island
      lastArtists   = ssrData.artists;
      lastAlbums    = ssrData.albums;
      lastTopTracks = ssrData.topTracks;
      saveGridHtml('albums', currentPeriod);
      saveTopTracksHtml(currentPeriod);
      saveTracksHtml();

      const ssrImages = ssrData.artistImages ?? {};
      if (Object.keys(ssrImages).length > 0) {
        // SSR resolved images — seed cache immediately, no client fetch needed
        lastImages = ssrImages;
        saveGridHtml('artists', currentPeriod);
        cacheSet<PeriodData>(`music_period_v4_${currentPeriod}`, {
          artists: lastArtists, albums: lastAlbums,
          images: ssrImages, topTracks: lastTopTracks,
        });
      } else if (ssrData.artists.length > 0) {
        // SSR didn't resolve images (cold start failure) — fetch client-side as fallback
        lastImages = {};
        const params = new URLSearchParams(ssrData.artists.map((a) => ['names', a.name]));
        fetch(`/api/artist-images?${params}`)
          .then((r) => r.ok ? r.json() as Promise<Record<string, ArtistData>> : Promise.resolve({} as Record<string, ArtistData>))
          .then((images) => {
            lastImages = images;
            if (viewMode === 'grid') {
              renderArtists(lastArtists, new Map(Object.entries(images)));
            } else {
              renderArtistsChart(lastArtists);
            }
            saveGridHtml('artists', currentPeriod);
            cacheSet<PeriodData>(`music_period_v4_${currentPeriod}`, {
              artists: lastArtists, albums: lastAlbums,
              images, topTracks: lastTopTracks,
            });
          })
          .catch(() => { saveGridHtml('artists', currentPeriod); });
      } else {
        lastImages = {};
        saveGridHtml('artists', currentPeriod);
      }
    } else {
      // Period mismatch or SSR failed — fetch client-side as before
      await Promise.allSettled([
        loadPeriodData(currentPeriod),
        loadStaticData(),
      ]);
    }
  }

  // astro:page-load fires on first load AND after every View Transition.
  // View Transitions replace DOM elements, so init() must re-bind event handlers
  // to the fresh elements on each navigation.
  document.addEventListener('astro:page-load', init);
</script>

