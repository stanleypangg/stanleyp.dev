---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const lfmUser = import.meta.env.PUBLIC_LASTFM_USERNAME;
---

<Layout title="Listening" description="Music I've been listening to.">
  <header class="page-header">
    <h1 class="page-title">Listening history</h1>
    <a
      class="lfm-link"
      href={`https://www.last.fm/user/${lfmUser}`}
      target="_blank"
      rel="noopener noreferrer"
    >last.fm ↗</a>
  </header>

  <div class="controls-spacer"></div>

  <!-- Controls: period + view toggle -->
  <div class="toggle controls-row" role="group" aria-label="Controls">
    <div class="period-group" role="group" aria-label="Time period">
      <button class="toggle-btn active" data-period="7day" aria-pressed="true" aria-label="Last 7 days">7d</button>
      <button class="toggle-btn" data-period="1month" aria-pressed="false" aria-label="Last month">1m</button>
      <button class="toggle-btn" data-period="12month" aria-pressed="false" aria-label="Last year">1y</button>
      <button class="toggle-btn" data-period="overall" aria-pressed="false">all time</button>
    </div>
    <div class="view-group" role="group" aria-label="View mode">
      <button class="toggle-btn active" data-view="grid" aria-pressed="true">grid</button>
      <button class="toggle-btn" data-view="chart" aria-pressed="false">chart</button>
    </div>
  </div>

  <hr class="rule" />

  <!-- Top Artists -->
  <section id="section-artists" aria-labelledby="label-artists">
    <h2 class="label" id="label-artists">Top artists</h2>
    <div class="grid" id="artists-grid">
      {Array.from({ length: 10 }, () => <div class="grid-item skeleton" />)}
    </div>
  </section>

  <hr class="rule" />

  <!-- Top Albums -->
  <section id="section-albums" aria-labelledby="label-albums">
    <h2 class="label" id="label-albums">Top albums</h2>
    <div class="grid" id="albums-grid">
      {Array.from({ length: 10 }, () => <div class="grid-item skeleton" />)}
    </div>
  </section>

  <hr class="rule" />

  <!-- Top Tracks -->
  <section id="section-top-tracks" aria-labelledby="label-top-tracks">
    <h2 class="label" id="label-top-tracks">Top tracks</h2>
    <div class="track-list" id="top-tracks-list">
      {Array.from({ length: 10 }, () => <div class="entry skeleton-row" />)}
    </div>
  </section>

  <hr class="rule" />

  <!-- Recent Tracks -->
  <section id="section-tracks" aria-labelledby="label-tracks">
    <h2 class="label" id="label-tracks">Recent tracks</h2>
    <div class="track-list" id="track-list">
      {Array.from({ length: 10 }, () => <div class="entry skeleton-row" />)}
    </div>
  </section>

<script is:inline data-astro-rerun>
  // Restore the active period toggle button state synchronously before the module loads.
  (function () {
    try {
      var period = localStorage.getItem('music_last_period') || '7day';
      if (period !== '7day') {
        document.querySelectorAll('[data-period]').forEach(function (b) {
          var isActive = b.getAttribute('data-period') === period;
          b.classList.toggle('active', isActive);
          b.setAttribute('aria-pressed', String(isActive));
        });
      }
    } catch (_) { /* localStorage unavailable */ }
  })();
</script>

<script>
  import { getTopArtists, getTopAlbums, getTopTracks, getRecentTracks } from '../lib/lastfm';
  import type { Period, ArtistStat, AlbumStat, TrackStat, Track } from '../lib/lastfm';
  import { esc, formatPlaycount, formatTimestamp } from '../lib/music-utils';

  const API_KEY = import.meta.env.PUBLIC_LASTFM_API_KEY;
  const USERNAME = import.meta.env.PUBLIC_LASTFM_USERNAME;

  // ── localStorage cache ────────────────────────────────────────────────────
  const TTL = {
    period:   60 * 60 * 1000,   // 1 hour  — artist/album stats change slowly
    tracks:    5 * 60 * 1000,   // 5 min   — recent tracks change frequently
  };

  interface CacheEntry<T> { data: T; ts: number }
  interface ArtistData { imageUrl: string | null; spotifyUrl: string | null; }

  interface PeriodData {
    artists:    ArtistStat[];
    albums:     AlbumStat[];
    images:     Record<string, ArtistData>;
    topTracks:  TrackStat[];
  }

  function cacheGet<T>(key: string, ttl: number): T | null {
    try {
      const raw = localStorage.getItem(key);
      if (!raw) return null;
      const { data, ts }: CacheEntry<T> = JSON.parse(raw);
      if (Date.now() - ts > ttl) return null;
      return data;
    } catch { return null; }
  }

  function cacheSet<T>(key: string, data: T): void {
    try {
      localStorage.setItem(key, JSON.stringify({ data, ts: Date.now() }));
    } catch { /* storage quota exceeded — ignore */ }
  }

  // ── Render helpers ────────────────────────────────────────────────────────
  async function fadeSwap(el: HTMLElement, html: string): Promise<void> {
    el.innerHTML = html;
  }

  async function renderArtists(artists: ArtistStat[], images: Map<string, ArtistData>, animate = true) {
    const grid = document.getElementById('artists-grid')!;
    grid.classList.remove('chart-view');
    const html = artists.map((a, i) => {
      const data = images.get(a.name);
      const animStyle = animate ? `animation-delay:${i * 50}ms` : `animation:none`;
      const imgEl = data?.imageUrl
        ? `<img src="${esc(data.imageUrl)}" alt="${esc(a.name)}" width="300" height="300" loading="lazy" decoding="async" style="${animStyle}" />`
        : `<div class="img-placeholder" aria-hidden="true" style="${animStyle}"></div>`;
      const href = data?.spotifyUrl ?? a.url;
      return `
        <div class="grid-item">
          <a href="${esc(href)}" target="_blank" rel="noopener noreferrer">
            ${imgEl}
            <div class="item-overlay">
              <span class="item-name">${esc(a.name)}</span>
              <span class="item-meta">${formatPlaycount(a.playcount)}</span>
            </div>
          </a>
        </div>`;
    }).join('');
    await fadeSwap(grid, html);
  }

  async function renderAlbums(albums: AlbumStat[], animate = true) {
    const grid = document.getElementById('albums-grid')!;
    grid.classList.remove('chart-view');
    const html = albums.map((a, i) => {
      const animStyle = animate ? `animation-delay:${i * 50}ms` : `animation:none`;
      const imgEl = a.imageUrl
        ? `<img src="${esc(a.imageUrl)}" alt="${esc(a.name)}" width="300" height="300" loading="lazy" decoding="async" style="${animStyle}" />`
        : `<div class="img-placeholder" aria-hidden="true" style="${animStyle}"></div>`;
      return `
        <div class="grid-item">
          <a href="${esc(a.url)}" target="_blank" rel="noopener noreferrer">
            ${imgEl}
            <div class="item-overlay">
              <span class="item-name">${esc(a.name)}</span>
              <span class="item-meta">${esc(a.artist)} · ${formatPlaycount(a.playcount)}</span>
            </div>
          </a>
        </div>`;
    }).join('');
    await fadeSwap(grid, html);
  }

  function animateBars(grid: HTMLElement) {
    // Double rAF: first ensures elements are in DOM, second ensures initial scaleY(0) is painted
    requestAnimationFrame(() => requestAnimationFrame(() => {
      grid.querySelectorAll<HTMLElement>('.vchart-bar').forEach((bar, i) => {
        bar.style.transitionDelay = `${i * 50}ms`;
        bar.style.transform = 'scaleY(1)';
      });
    }));
  }

  async function renderArtistsChart(artists: ArtistStat[]) {
    const grid = document.getElementById('artists-grid')!;
    grid.classList.add('chart-view');
    const max = artists[0]?.playcount ?? 1;
    const images = new Map(Object.entries(lastImages));
    const html = `<div class="vchart">${artists.map((a) => {
      const pct = (a.playcount / max) * 100;
      const data = images.get(a.name);
      const imgEl = data?.imageUrl
        ? `<img src="${esc(data.imageUrl)}" alt="" width="44" height="44" loading="lazy" />`
        : `<div class="vchart-img-placeholder"></div>`;
      return `
        <div class="vchart-col">
          <span class="vchart-count">${a.playcount.toLocaleString()}</span>
          <div class="vchart-bar-area">
            <div class="vchart-bar" style="height:${pct}%"></div>
          </div>
          <div class="vchart-img">${imgEl}</div>
          <span class="vchart-name" title="${esc(a.name)}">${esc(a.name)}</span>
        </div>`;
    }).join('')}</div>`;
    await fadeSwap(grid, html);
    animateBars(grid);
  }

  async function renderAlbumsChart(albums: AlbumStat[]) {
    const grid = document.getElementById('albums-grid')!;
    grid.classList.add('chart-view');
    const max = albums[0]?.playcount ?? 1;
    const html = `<div class="vchart">${albums.map((a) => {
      const pct = (a.playcount / max) * 100;
      const imgEl = a.imageUrl
        ? `<img src="${esc(a.imageUrl)}" alt="" width="44" height="44" loading="lazy" />`
        : `<div class="vchart-img-placeholder"></div>`;
      return `
        <div class="vchart-col">
          <span class="vchart-count">${a.playcount.toLocaleString()}</span>
          <div class="vchart-bar-area">
            <div class="vchart-bar" style="height:${pct}%"></div>
          </div>
          <div class="vchart-img">${imgEl}</div>
          <span class="vchart-name" title="${esc(a.name)}">${esc(a.name)}</span>
        </div>`;
    }).join('')}</div>`;
    await fadeSwap(grid, html);
    animateBars(grid);
  }

  async function renderTracks(tracks: Track[]) {
    const list = document.getElementById('track-list')!;
    const html = tracks.map((t) => {
      const isNow = t.timestamp === null;
      const metaEl = isNow
        ? `<span class="track-live-wave" role="img" aria-label="Now playing">
             <span class="track-live-bar" aria-hidden="true"></span><span class="track-live-bar" aria-hidden="true"></span>
             <span class="track-live-bar" aria-hidden="true"></span><span class="track-live-bar" aria-hidden="true"></span>
           </span>`
        : `<span class="entry-meta">${formatTimestamp(t.timestamp)}</span>`;
      return `
        <div class="entry">
          <span class="entry-title">
            <a href="${esc(t.url)}" target="_blank" rel="noopener noreferrer" class="link">${esc(t.name)}</a>
            <span class="entry-sub"> · ${esc(t.artist)}</span>
          </span>
          ${metaEl}
        </div>`;
    }).join('');
    await fadeSwap(list, html);
  }

  async function renderTopTracks(tracks: TrackStat[]) {
    const list = document.getElementById('top-tracks-list')!;
    const html = tracks.map((t, i) => `
      <div class="entry entry--ranked">
        <span class="entry-rank" aria-hidden="true">${String(i + 1).padStart(2, '0')}</span>
        <span class="entry-title">
          <a href="${esc(t.url)}" target="_blank" rel="noopener noreferrer" class="link">${esc(t.name)}</a>
          <span class="entry-sub"> · ${esc(t.artist)}</span>
        </span>
        <span class="entry-meta">${formatPlaycount(t.playcount)}</span>
      </div>`).join('');
    await fadeSwap(list, html);
  }

  function showError(sectionId: string) {
    const el = document.getElementById(sectionId);
    if (!el) return;
    const content = el.querySelector('[id$="-grid"], [id$="-list"]');
    if (content) content.innerHTML = '<p class="unavailable">unavailable</p>';
  }

  function showSkeletons(): void {
    const skeletonGrid = Array.from({ length: 10 }, () => '<div class="grid-item skeleton"></div>').join('');
    const skeletonList = Array.from({ length: 10 }, () => '<div class="entry skeleton-row"></div>').join('');
    const artistsGrid = document.getElementById('artists-grid');
    const albumsGrid  = document.getElementById('albums-grid');
    const topTracksList = document.getElementById('top-tracks-list');
    if (artistsGrid) artistsGrid.innerHTML = skeletonGrid;
    if (albumsGrid)  albumsGrid.innerHTML  = skeletonGrid;
    if (topTracksList) topTracksList.innerHTML = skeletonList;
  }

  // ── State — reset by init() on every navigation ───────────────────────────
  let currentPeriod: Period = '7day';
  let viewMode: 'grid' | 'chart' = 'grid';
  let prefetchController: AbortController | null = null;

  // Last successfully loaded data — used for instant re-render on view toggle
  let lastArtists:   ArtistStat[] = [];
  let lastImages:    Record<string, ArtistData> = {};
  let lastAlbums:    AlbumStat[]  = [];
  let lastTopTracks: TrackStat[]  = [];

  async function loadPeriodData(period: Period, forceRender = false) {
    // Serve from cache immediately if fresh
    const cacheKey = `music_period_v4_${period}`;
    const cached = cacheGet<PeriodData>(cacheKey, TTL.period);
    if (cached) {
      lastArtists   = cached.artists;
      lastImages    = cached.images;
      lastAlbums    = cached.albums;
      lastTopTracks = cached.topTracks ?? [];
      if (viewMode === 'chart') {
        await renderArtistsChart(cached.artists);
        await renderAlbumsChart(cached.albums);
      } else {
        await renderArtists(cached.artists, new Map(Object.entries(cached.images)), !forceRender);
        await renderAlbums(cached.albums, !forceRender);
        if (cached.topTracks) {
          await renderTopTracks(cached.topTracks);
        }
      }
      return;
    }

    const [artistsResult, albumsResult, topTracksResult] = await Promise.allSettled([
      getTopArtists(period, 10, API_KEY, USERNAME),
      getTopAlbums(period, 10, API_KEY, USERNAME),
      getTopTracks(period, 10, API_KEY, USERNAME),
    ]);

    // Albums have their own images from Last.fm — render immediately
    if (albumsResult.status === 'fulfilled') {
      lastAlbums = albumsResult.value;
      if (viewMode === 'chart') {
        await renderAlbumsChart(albumsResult.value);
      } else {
        await renderAlbums(albumsResult.value, !forceRender);
      }
    } else {
      showError('section-albums');
    }

    if (topTracksResult.status === 'fulfilled') {
      lastTopTracks = topTracksResult.value;
      await renderTopTracks(topTracksResult.value);
    } else {
      showError('section-top-tracks');
    }

    if (artistsResult.status === 'fulfilled') {
      const artists = artistsResult.value;

      // One batched server-side call instead of 10 client→Spotify calls.
      // The server caches results at the CDN layer (s-maxage=3600).
      let images: Record<string, ArtistData> = {};
      try {
        const imgController = new AbortController();
        const imgTimeout = setTimeout(() => imgController.abort(), 10000);
        const params = new URLSearchParams(artists.map((a) => ['names', a.name]));
        const res = await fetch(`/api/artist-images?${params}`, { signal: imgController.signal });
        clearTimeout(imgTimeout);
        if (res.ok) images = await res.json() as Record<string, ArtistData>;
      } catch { /* images are non-critical */ }

      lastArtists = artists;
      lastImages  = images;

      if (viewMode === 'chart') {
        await renderArtistsChart(artists);
      } else {
        await renderArtists(artists, new Map(Object.entries(images)), !forceRender);
      }

      if (albumsResult.status === 'fulfilled' && topTracksResult.status === 'fulfilled') {
        cacheSet<PeriodData>(cacheKey, { artists, albums: albumsResult.value, images, topTracks: topTracksResult.value });
      }
    } else {
      showError('section-artists');
    }
  }

  // ── Background prefetch — warms cache for all other periods after idle ───
  async function prefetchRemainingPeriods(): Promise<void> {
    prefetchController = new AbortController();
    const signal = prefetchController.signal;
    const allPeriods: Period[] = ['7day', '1month', '12month', 'overall'];
    const periodsToFetch = allPeriods.filter((p) =>
      p !== currentPeriod && !cacheGet<PeriodData>(`music_period_v4_${p}`, TTL.period)
    );

    for (const period of periodsToFetch) {
      if (signal.aborted) return;
      try {
        const [artistsResult, albumsResult, topTracksResult] = await Promise.allSettled([
          getTopArtists(period, 10, API_KEY, USERNAME),
          getTopAlbums(period, 10, API_KEY, USERNAME),
          getTopTracks(period, 10, API_KEY, USERNAME),
        ]);
        if (signal.aborted) return;
        if (artistsResult.status !== 'fulfilled' || albumsResult.status !== 'fulfilled' || topTracksResult.status !== 'fulfilled') continue;

        const artists   = artistsResult.value;
        const albums    = albumsResult.value;
        const topTracks = topTracksResult.value;

        let images: Record<string, ArtistData> = {};
        if (artists.length > 0) {
          try {
            const params = new URLSearchParams(artists.map((a) => ['names', a.name]));
            const res = await fetch(`/api/artist-images?${params}`, { signal });
            if (res.ok) images = await res.json() as Record<string, ArtistData>;
          } catch { /* images non-critical */ }
        }
        if (signal.aborted) return;

        cacheSet<PeriodData>(`music_period_v4_${period}`, { artists, albums, images, topTracks });
      } catch { /* ignore prefetch errors */ }
    }
  }

  async function loadStaticData() {
    const cachedTracks = cacheGet<Track[]>('music_tracks', TTL.tracks);
    if (cachedTracks) {
      const trackList = document.getElementById('track-list');
      if (trackList && trackList.querySelector('.skeleton-row')) {
        await renderTracks(cachedTracks);
      }
      return;
    }

    await getRecentTracks(10, API_KEY, USERNAME)
      .then(async (tracks) => { await renderTracks(tracks); cacheSet('music_tracks', tracks); })
      .catch(() => showError('section-tracks'));
  }

  // ── Init — runs on every navigation via astro:page-load ──────────────────
  // Module scripts are ES module singletons (only evaluated once), so all
  // event listener binding and data loading must happen inside this function
  // which is re-called by astro:page-load on every View Transition navigation.
  async function init() {
    // Reset per-navigation state
    currentPeriod = (() => {
      try { return (localStorage.getItem('music_last_period') as Period) || '7day'; } catch { return '7day'; }
    })();
    viewMode = 'grid';
    lastArtists   = [];
    lastImages    = {};
    lastAlbums    = [];
    lastTopTracks = [];

    // ── Period toggle ──────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('.toggle-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!btn.dataset.period) return;   // ignore view buttons
        const period = btn.dataset.period as Period;
        if (period === currentPeriod) return;
        currentPeriod = period;
        try { localStorage.setItem('music_last_period', period); } catch { /* ignore */ }

        document.querySelectorAll('[data-period]').forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');

        if (!cacheGet<PeriodData>(`music_period_v4_${period}`, TTL.period)) {
          showSkeletons();
        }
        await loadPeriodData(period, true);
      });
    });

    // ── View toggle ────────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('[data-view]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const mode = btn.dataset.view as 'grid' | 'chart';
        if (mode === viewMode) return;
        viewMode = mode;

        document.querySelectorAll('[data-view]').forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');

        if (viewMode === 'chart') {
          await renderArtistsChart(lastArtists);
          await renderAlbumsChart(lastAlbums);
        } else {
          await renderArtists(lastArtists, new Map(Object.entries(lastImages)));
          await renderAlbums(lastAlbums);
        }
      });
    });

    // ── Load data ──────────────────────────────────────────────────────────
    await Promise.allSettled([
      loadPeriodData(currentPeriod),
      loadStaticData(),
    ]);

    // Warm the cache for remaining periods during browser idle time
    const scheduleIdle = (window as Window & { requestIdleCallback?: (cb: () => void) => void }).requestIdleCallback
      ?? ((cb: () => void) => setTimeout(cb, 200));
    scheduleIdle(() => prefetchRemainingPeriods());
  }

  // astro:page-load fires on first load AND after every View Transition.
  // View Transitions replace DOM elements, so init() must re-bind event handlers
  // to the fresh elements on each navigation.
  document.addEventListener('astro:page-load', init);

  // Abort any in-flight prefetch when navigating away via View Transition
  document.addEventListener('astro:before-swap', () => {
    if (prefetchController) {
      prefetchController.abort();
      prefetchController = null;
    }
  });
</script>

<style>
  /* ── Page entrance ─────────────────────────────────────────── */
  /* Use opacity-only fade (no translate) — the translate on surrounding elements
     creates a perceptual illusion that the image grid is drifting upward. */
  .controls-spacer,
  .toggle {
    animation: enter-fade 800ms ease-out 110ms both;
  }

  .page-header {
    margin-bottom: 0;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    animation: enter-fade 800ms ease-out both;
  }

  .lfm-link {
    font-size: var(--text-xs);
    color: var(--muted);
    letter-spacing: 0.04em;
    transition: color 250ms;
  }

  .lfm-link:hover {
    color: var(--fg);
  }

  .page-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-optical-sizing: auto;
    font-size: var(--text-lg);
    letter-spacing: -0.01em;
  }

  /* Controls layout */
  .controls-spacer { margin-top: 1.5rem; }

  .controls-row { justify-content: space-between; }

  .period-group {
    display: flex;
    gap: 1.5rem;
  }

  .view-group {
    display: flex;
    gap: 1rem;
  }

  /* Period toggle */
  .toggle {
    display: flex;
    gap: 1.5rem;
  }

  .toggle-btn {
    font-family: var(--font-text);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    text-transform: lowercase;
    color: var(--muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 250ms, transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .toggle-btn:hover,
  .toggle-btn.active {
    color: var(--fg);
    transform: translateX(0.4rem);
  }

  /* Grid (artists + albums) */
  .grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
  }

  :global(.grid-item) {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
  }

  :global(.grid-item a) {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  :global(.grid-item) {
    background: var(--subtle);
  }

  :global(.grid-item img),
  :global(.grid-item .img-placeholder) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  :global(.grid-item img),
  :global(.grid-item .img-placeholder) {
    animation: img-pop-in 500ms cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }

  :global(.grid-item img) {
    transition: transform 500ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  :global(.grid-item:hover img) {
    transform: scale(1.02);
  }

  @keyframes img-pop-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  :global(.item-overlay) {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.5rem 0.625rem 0.5rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.96) 0%, rgba(0, 0, 0, 0.5) 50%, rgba(0, 0, 0, 0) 100%);
    pointer-events: none;
  }

  :global(.item-name) {
    display: block;
    font-size: var(--text-xs);
    color: #fff;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.item-meta) {
    display: block;
    font-size: var(--text-2xs);
