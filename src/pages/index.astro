</div>
</Layout>

<style>
  /* Fill main height; hero absorbs all free space below it */
  .home-layout {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 3dvh, 2.5rem);
  }

  .hero {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 2rem;
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .hero-photo {
    width: clamp(110px, 18vw, 160px);
    flex-shrink: 0;
    border-radius: 2px;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    filter: grayscale(0.15);
    transition:
      transform 500ms cubic-bezier(0.16, 1, 0.3, 1),
      filter   500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-photo:hover img {
    transform: scale(1.04);
    filter: grayscale(0);
  }

  .display-name {
    font-family: var(--font-display);
    font-weight: 300;                /* fallback for non-variable fonts */
    font-optical-sizing: none;       /* manual opsz control via font-variation-settings */
    font-size: var(--text-2xl);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    width: fit-content;
    /* opsz 18 = compact text serifs; wght 300 = light */
    font-variation-settings: 'opsz' 18, 'wght' 300;
    transition: font-variation-settings 450ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* JS-gated — prevents flicker when transitioning width causes hover to retrigger */
  .display-name.is-hovered {
    font-variation-settings: 'opsz' 80, 'wght' 400;
  }

.tagline {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .bio {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.75;
    max-width: 44ch;
  }

  .role-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Logo + text + date — flat three-column row */
  .work-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition:
      opacity  250ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Spotlight: dim all rows when the list is hovered — cursor stays
     inside .role-list between items so the dim never resets mid-travel */
  .role-list:hover .work-item {
    opacity: 0.35;
  }

  /* Hovered row: restore + indent */
  .role-list:hover .work-item:hover {
    opacity: 1;
    transform: translateX(5px);
  }

  .item-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
    line-height: 1.3;
  }

  .work-role {
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .work-logo {
    height: 36px;
    width: 36px;
    flex-shrink: 0;
    object-fit: contain;
    filter: saturate(0.75);
    transition: filter 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .work-logo--round {
    border-radius: 4px;
  }

  /* UofT coat of arms */
  .edu-logo {
    height: 36px;
    width: 36px;
    flex-shrink: 0;
    object-fit: contain;
    filter: saturate(0.8);
    transition: filter 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Logo: restore saturation on hover — subtle color reveal */
  .work-item:hover .work-logo,
  .work-item:hover .edu-logo {
    filter: saturate(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .work-item {
      transition: opacity 250ms;
    }
    .work-item:hover {
      transform: none;
    }
    .work-logo,
    .edu-logo {
      transition: none;
    }
  }

  /* ── Page entrance ─────────────────────────────────────────── */
  @keyframes enter-up {
    from { opacity: 0; translate: 0 10px; }
    to   { opacity: 1; translate: 0 0;   }
  }

  .hero {
    animation: enter-up 560ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  section:nth-of-type(1) {
    animation: enter-up 560ms cubic-bezier(0.16, 1, 0.3, 1) 90ms both;
  }
  section:nth-of-type(2) {
    animation: enter-up 560ms cubic-bezier(0.16, 1, 0.3, 1) 170ms both;
  }
  section:nth-of-type(3) {
    animation: enter-up 560ms cubic-bezier(0.16, 1, 0.3, 1) 250ms both;
  }
  section:nth-of-type(4) {
    animation: enter-up 560ms cubic-bezier(0.16, 1, 0.3, 1) 330ms both;
  }

  /* ── Label letter-spacing expand ───────────────────────────── */
  /* Runs alongside the section entrance — tracking breathes open
     as each section arrives. Delays mirror section enter-up delays. */
  section:nth-of-type(1) :global(.label) {
    animation: expand-tracking 700ms cubic-bezier(0.16, 1, 0.3, 1) 90ms both;
  }
  section:nth-of-type(2) :global(.label) {
    animation: expand-tracking 700ms cubic-bezier(0.16, 1, 0.3, 1) 170ms both;
  }
  section:nth-of-type(3) :global(.label) {
    animation: expand-tracking 700ms cubic-bezier(0.16, 1, 0.3, 1) 250ms both;
  }
  section:nth-of-type(4) :global(.label) {
    animation: expand-tracking 700ms cubic-bezier(0.16, 1, 0.3, 1) 330ms both;
  }

  .elsewhere-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.5rem;
  }

  .elsewhere-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: none;
    transition: color 200ms;
  }

  .elsewhere-list a:hover {
    color: var(--fg);
  }

  .elsewhere-list svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero, section {
      animation: none;
    }
    /* No transition = no flicker: safe to use plain :hover */
    .display-name {
      transition: none;
    }
    .display-name:hover {
      font-variation-settings: 'opsz' 80, 'wght' 400;
    }
    section :global(.label) {
      animation: none;
    }
  }
</style>

<script>
  // Hover state machine for .display-name.
  // Problem: width:fit-content resizes during the font-variation-settings transition,
  // so the element's right edge slides through the cursor position and retriggers
  // hover — causing the compressed/expanded oscillation.
  // Fix: lock state changes during transitions; flush to final desired state on transitionend.
  function initNameHover() {
    const name = document.querySelector('.display-name') as HTMLElement | null;
    if (!name || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let over = false;
    let applied = false;
    let busy = false;

    function sync() {
      if (busy || over === applied) return;
      applied = over;
      name.classList.toggle('is-hovered', applied);
      busy = true;
    }

    name.addEventListener('mouseenter', () => { over = true;  sync(); });
    name.addEventListener('mouseleave', () => { over = false; sync(); });
    name.addEventListener('transitionend', (e) => {
      if ((e as TransitionEvent).propertyName !== 'font-variation-settings') return;
      busy = false;
      sync(); // flush any state change that arrived during the transition
    });
  }

  initNameHover();
  document.addEventListener('astro:after-swap', initNameHover);
</script>
