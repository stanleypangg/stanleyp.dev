---
import Layout from '../layouts/Layout.astro';
import NowPlaying from '../components/NowPlaying.astro';
---

<Layout title="Software Engineer" description="Stanley Pang — CS student at the University of Toronto, software engineer intern at Shopify. Building software that actually works.">
<div class="home-layout">
  <!-- Hero -->
  <header class="hero">
    <div class="hero-text">
      <h1 class="display-name">Stanley Pang</h1>
<p class="tagline">Software Engineer</p>
      <p class="bio">
        I like making software that actually works for people, and I like understanding
        exactly how it does that. <span class="bio-detail">Studying CS at the University of Toronto,
        interning at Shopify.</span>
      </p>
    </div>
    <div class="hero-photo">
      <img src="/headshot.webp" alt="Stanley Pang" width="320" height="335" loading="eager" fetchpriority="high" />
    </div>
  </header>

  <!-- Work -->
  <section aria-labelledby="section-work">
    <h2 class="label" id="section-work">Work</h2>
    <div class="role-list">
      <div class="work-item">
        <img src="/shopify-logo.svg" alt="Shopify" class="work-logo" width="36" height="36" loading="lazy" />
        <div class="item-text">
          <span class="entry-title">Shopify</span>
          <p class="work-role">Software Engineer Intern</p>
        </div>
        <span class="entry-meta">Winter 2026</span>
      </div>
      <div class="work-item">
        <img src="/boost-collective.jpg" alt="Boost Collective" class="work-logo work-logo--round" width="36" height="36" loading="lazy" decoding="async" />
        <div class="item-text">
          <span class="entry-title">Boost Collective</span>
          <p class="work-role">Software Engineer Intern</p>
        </div>
        <span class="entry-meta">Fall 2025</span>
      </div>
      <div class="work-item">
        <img src="/spglobal-logo.jpg" alt="S&amp;P Global" class="work-logo work-logo--round" width="36" height="36" loading="lazy" decoding="async" />
        <div class="item-text">
          <span class="entry-title">S&amp;P Global</span>
          <p class="work-role">Software Developer Intern</p>
        </div>
        <span class="entry-meta">Summer 2025</span>
      </div>
    </div>
  </section>


  <!-- Education -->
  <section aria-labelledby="section-education">
    <h2 class="label" id="section-education">Education</h2>
    <div class="role-list">
      <div class="work-item">
        <img src="/uoft-logo-72.webp" alt="University of Toronto" class="edu-logo" width="36" height="36" loading="lazy" />
        <div class="item-text">
          <span class="entry-title">University of Toronto</span>
          <p class="work-role">BSc Computer Science · Math &amp; Stats Minor</p>
        </div>
        <span class="entry-meta">2022 - 2027</span>
      </div>
    </div>
  </section>


  <!-- Listening -->
  <section aria-labelledby="listening-label">
    <h2 class="label" id="listening-label">Listening</h2>
    <NowPlaying />
  </section>

  <!-- Elsewhere -->
  <section aria-labelledby="section-elsewhere">
    <h2 class="label" id="section-elsewhere">Elsewhere</h2>
    <ul class="elsewhere-list">
      <li>
        <a href="https://github.com/stanleypangg" target="_blank" rel="me noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          GitHub
        </a>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/stanleypangg/" target="_blank" rel="me noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </li>
      <li>
        <a href="https://x.com/stanleypangg" target="_blank" rel="me noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
          Twitter/X
        </a>
      </li>
      <li>
        <a href="mailto:stanley.pang@mail.utoronto.ca">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
          Email
        </a>
      </li>
    </ul>
  </section>
</div>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Stanley Pang",
  "url": "https://stanleyp.dev",
  "jobTitle": "Software Engineer",
  "description": "CS student at the University of Toronto, software engineer intern at Shopify.",
  "alumniOf": {
    "@type": "EducationalOrganization",
    "name": "University of Toronto"
  },
  "sameAs": [
    "https://github.com/stanleypangg",
    "https://www.linkedin.com/in/stanleypangg/",
    "https://x.com/stanleypangg"
  ]
})} />
</Layout>

<style>
  /* Fill main height; hero absorbs all free space below it */
  .home-layout {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 3dvh, 2.5rem);
  }

  .hero {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 2rem;
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .hero-photo {
    width: clamp(110px, 18vw, 160px);
    flex-shrink: 0;
    border-radius: 2px;
    overflow: hidden;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    filter: grayscale(0.15);
    transition:
      transform 500ms cubic-bezier(0.16, 1, 0.3, 1),
      filter   500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-photo:hover img {
    transform: scale(1.04);
    filter: grayscale(0);
  }

  .display-name {
    font-family: var(--font-display);
    font-weight: 300;                /* fallback for non-variable fonts */
    font-optical-sizing: none;       /* manual opsz control via font-variation-settings */
    font-size: var(--text-2xl);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    width: fit-content;
    /* opsz 18 = compact text serifs; wght 300 = light */
    font-variation-settings: 'opsz' 18, 'wght' 300;
    transition: font-variation-settings 450ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* JS-gated — prevents flicker when transitioning width causes hover to retrigger */
  .display-name.is-hovered {
    font-variation-settings: 'opsz' 80, 'wght' 400;
  }

.tagline {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .bio {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.75;
    max-width: 44ch;
  }

  .role-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Logo + text + date — flat three-column row */
  .work-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition:
      opacity  250ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Spotlight: dim all rows when the list is hovered — cursor stays
     inside .role-list between items so the dim never resets mid-travel */
  .role-list:hover .work-item {
    opacity: 0.35;
  }

  /* Hovered row: restore + indent */
  .role-list:hover .work-item:hover {
    opacity: 1;
    transform: translateX(5px);
  }

  .item-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
    line-height: 1.3;
  }

  .work-role {
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .work-logo {
    height: 36px;
    width: 36px;
    flex-shrink: 0;
    object-fit: contain;
    filter: saturate(0.75);
    transition: filter 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .work-logo--round {
    border-radius: 4px;
  }

  /* UofT coat of arms */
  .edu-logo {
    height: 36px;
    width: 36px;
    flex-shrink: 0;
    object-fit: contain;
    filter: saturate(0.8);
    transition: filter 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Logo: restore saturation on hover — subtle color reveal */
  .work-item:hover .work-logo,
  .work-item:hover .edu-logo {
    filter: saturate(1);
  }

  /* ── Mobile ────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .hero-photo {
      width: clamp(112px, 30vw, 140px);
      flex-shrink: 0;
      overflow: visible;
    }

    .hero-photo img {
      width: calc(100% + 1.5rem);
      max-width: none;
      margin-left: -1.5rem;
      object-position: top 30%;
    }

    .bio-detail {
      display: none;
    }

    /* Tighten the meta date so it doesn't crowd on narrow widths */
    .entry-meta {
      font-size: var(--text-2xs);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-item {
      transition: opacity 250ms;
    }
    .work-item:hover {
      transform: none;
    }
    .work-logo,
    .edu-logo {
      transition: none;
    }
  }

  /* ── Page entrance ─────────────────────────────────────────── */
  /* Explicit opacity: 0 prevents a single-frame flash when the keyframes
     definition lives in a separate CSS chunk from the animation property.
     The running animation overrides this; forwards fill keeps opacity: 1. */
  .hero,
  section {
    opacity: 0;
  }

  .hero {
    animation: enter-fade 800ms ease-out both;
  }

  section:nth-of-type(1) {
    animation: enter-fade 800ms ease-out 110ms both;
  }
  section:nth-of-type(2) {
    animation: enter-fade 800ms ease-out 210ms both;
  }
  section:nth-of-type(3) {
    animation: enter-fade 800ms ease-out 310ms both;
  }
  section:nth-of-type(4) {
    animation: enter-fade 800ms ease-out 410ms both;
  }

  .elsewhere-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.5rem;
  }

  .elsewhere-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: none;
    transition: color 200ms;
  }

  .elsewhere-list a:hover {
    color: var(--fg);
  }

  .elsewhere-list svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero, section {
      animation: none;
      opacity: 1;
    }
    /* No transition = no flicker: safe to use plain :hover */
    .display-name {
      transition: none;
    }
    .display-name:hover {
      font-variation-settings: 'opsz' 80, 'wght' 400;
    }
  }
</style>

<script>
  // Hover state machine for .display-name.
  // Problem: width:fit-content resizes during the font-variation-settings transition,
  // so the element's right edge slides through the cursor position and retriggers
  // hover — causing the compressed/expanded oscillation.
  // Fix: lock state changes during transitions; flush to final desired state on transitionend.
  function initNameHover() {
    const name = document.querySelector('.display-name') as HTMLElement | null;
    if (!name || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let over = false;
    let applied = false;
    let busy = false;

    function sync() {
      if (busy || over === applied) return;
      applied = over;
      name.classList.toggle('is-hovered', applied);
      busy = true;
    }

    name.addEventListener('mouseenter', () => { over = true;  sync(); });
    name.addEventListener('mouseleave', () => { over = false; sync(); });
    name.addEventListener('transitionend', (e) => {
      if ((e as TransitionEvent).propertyName !== 'font-variation-settings') return;
      busy = false;
      sync(); // flush any state change that arrived during the transition
    });
  }

  // Mouse-driven Y-axis spin on the hero photo.
  // Horizontal mouse movement adds angular momentum — fast swipe = fast spin.
  // Left/right movement = respective spin direction. Rotation is unbounded
  // (full 360° like a coin/fan). When idle, friction decays the spin, then a
  // critically damped spring snaps to the nearest face-forward position (0°/360°).
  function initPhotoSpin() {
    const photo = document.querySelector<HTMLElement>('.hero-photo');
    if (!photo) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let rotation     = 0;   // unbounded degrees (fed directly to rotateY)
    let angVel       = 0;   // degrees/frame of angular momentum
    let springVel    = 0;   // spring return velocity (degrees/frame)
    let pendingDelta = 0;   // mouse X delta accumulated since last frame
    let lastX: number | null = null;
    let rafId: number | null = null;
    let isMoving = false;
    let moveTimer = 0;

    const SENSITIVITY = 0.35; // angular velocity added per accumulated pixel
    const MAX_VEL     = 14;   // degrees/frame cap (~840 deg/s, ~2.3 rps)
    const FRICTION    = 0.965; // velocity multiplier per frame when coasting
    const VEL_THRESH  = 0.25; // switch to spring-return below this angular speed
    const K           = 120;  // spring stiffness
    const C           = 22;   // critical damping (≈ 2·√120)
    const DT          = 1 / 60;

    function tick() {
      // Inject accumulated mouse input as angular velocity
      if (pendingDelta !== 0) {
        angVel       = Math.max(-MAX_VEL, Math.min(MAX_VEL, angVel + pendingDelta * SENSITIVITY));
        pendingDelta = 0;
      }

      const isReturning = !isMoving && Math.abs(angVel) < VEL_THRESH;

      if (!isReturning) {
        // SPINNING / COASTING: advance by angular velocity, apply friction when not driven
        rotation += angVel;
        if (!isMoving) angVel *= FRICTION;
      } else {
        // RETURNING: spring toward nearest face-forward angle (shortest path)
        angVel = 0;
        const mod    = ((rotation % 360) + 360) % 360;        // 0–359
        const offset = mod <= 180 ? -mod : (360 - mod);       // shortest arc to 0° multiple
        const target = rotation + offset;
        const disp   = rotation - target;
        const force  = -K * disp - C * springVel;
        springVel   += force * DT;
        rotation    += springVel * DT;

        if (Math.abs(disp) < 0.05 && Math.abs(springVel) < 0.05) {
          rotation               = target;
          springVel              = 0;
          photo.style.transform  = '';
          photo.style.willChange = 'auto';
          rafId = null;
          return;
        }
      }

      photo.style.transform = `perspective(600px) rotateY(${rotation.toFixed(3)}deg)`;
      rafId = requestAnimationFrame(tick);
    }

    function ensureTicking() {
      if (rafId === null) {
        photo.style.willChange = 'transform';
        rafId = requestAnimationFrame(tick);
      }
    }

    function onMouseMove(e: MouseEvent) {
      if (lastX !== null) pendingDelta += e.clientX - lastX;
      lastX    = e.clientX;
      isMoving = true;
      clearTimeout(moveTimer);
      moveTimer = window.setTimeout(() => { isMoving = false; }, 80);
      ensureTicking();
    }

    function onMouseEnter(e: MouseEvent) { lastX = e.clientX; }
    function onMouseLeave()              { lastX = null; isMoving = false; ensureTicking(); }

    photo.addEventListener('mousemove',  onMouseMove);
    photo.addEventListener('mouseenter', onMouseEnter);
    photo.addEventListener('mouseleave', onMouseLeave);

    return () => {
      photo.removeEventListener('mousemove',  onMouseMove);
      photo.removeEventListener('mouseenter', onMouseEnter);
      photo.removeEventListener('mouseleave', onMouseLeave);
      if (rafId !== null) cancelAnimationFrame(rafId);
      photo.style.transform  = '';
      photo.style.willChange = 'auto';
    };
  }

  initNameHover();

  let spinCleanup = initPhotoSpin();

  document.addEventListener('astro:after-swap', () => {
    initNameHover();
    spinCleanup?.();
    spinCleanup = initPhotoSpin();
  });
</script>
