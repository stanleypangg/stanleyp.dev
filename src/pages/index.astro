---
import Layout from '../layouts/Layout.astro';
import NowPlaying from '../components/NowPlaying.astro';
---

<Layout title="Stanley Pang — Software Engineer">
<div class="home-layout">
  <!-- Hero -->
  <header class="hero">
    <div class="hero-text">
      <h1 class="display-name">Stanley Pang</h1>
<p class="tagline">Software Engineer!</p>
      <p class="bio">
        I like making software that actually works for people, and I like understanding
        exactly how it does that. Studying CS at the University of Toronto,
        interning at Shopify.
      </p>
    </div>
    <div class="hero-photo">
      <img src="/headshot.webp" alt="Stanley Pang" loading="eager" fetchpriority="high" />
    </div>
  </header>

  <!-- Work -->
  <section>
    <span class="label">Work</span>
    <div class="role-list">
      <div class="work-item">
        <img src="/shopify-logo.svg" alt="Shopify" class="work-logo" />
        <div class="item-text">
          <span class="entry-title">Shopify</span>
          <p class="work-role">Software Engineer Intern</p>
        </div>
        <span class="entry-meta">Winter 2026</span>
      </div>
      <div class="work-item">
        <img src="/boost-collective.jpg" alt="Boost Collective" class="work-logo work-logo--round" />
        <div class="item-text">
          <span class="entry-title">Boost Collective</span>
          <p class="work-role">Software Engineer Intern</p>
        </div>
        <span class="entry-meta">Fall 2025</span>
      </div>
      <div class="work-item">
        <img src="/spglobal-logo.jpg" alt="S&P Global" class="work-logo work-logo--round" />
        <div class="item-text">
          <span class="entry-title">S&amp;P Global</span>
          <p class="work-role">Software Developer Intern</p>
        </div>
        <span class="entry-meta">Summer 2025</span>
      </div>
    </div>
  </section>


  <!-- Education -->
  <section>
    <span class="label">Education</span>
    <div class="role-list">
      <div class="work-item">
        <img src="/uoft-logo.svg" alt="University of Toronto" class="edu-logo" />
        <div class="item-text">
          <span class="entry-title">University of Toronto</span>
          <p class="work-role">BSc Computer Science · Math &amp; Stats Minor</p>
        </div>
        <span class="entry-meta">2022 - 2027</span>
      </div>
    </div>
  </section>


  <!-- Listening -->
  <section>
    <span class="label" id="listening-label">Listening</span>
    <NowPlaying />
  </section>

  <!-- Elsewhere -->
  <section>
    <span class="label">Elsewhere</span>
    <ul class="elsewhere-list">
      <li>
        <a href="https://github.com/stanleypangg" target="_blank" rel="noopener noreferrer">
