---
import Layout from '../layouts/Layout.astro';
import NowPlaying from '../components/NowPlaying.astro';
---

<Layout title="Stanley Pang — Software Engineer">
  <!-- Hero -->
  <header>
    <h1 class="display-name">
      Stanley Pang
    </h1>
    <p class="tagline">
      Software engineer. Building for the web.<br />
      Currently at <span class="fg">Shopify</span>.
    </p>
  </header>

  <!-- Work -->
  <section>
    <span class="label">Work</span>
    <div class="role-list">
      <div class="entry">
        <span class="entry-title">
          Software Engineer Intern <span class="entry-sub">at</span> Shopify
        </span>
        <span class="entry-meta">Jan 2025–</span>
      </div>
      <div class="entry">
        <span class="entry-title">
          Software Engineer Intern <span class="entry-sub">at</span> Boost Collective
        </span>
        <span class="entry-meta">Sep–Dec 2025</span>
      </div>
      <div class="entry">
        <span class="entry-title">
          Software Developer Intern <span class="entry-sub">at</span> S&amp;P Global
        </span>
        <span class="entry-meta">May–Aug 2025</span>
      </div>
    </div>
  </section>


  <!-- About -->
  <section>
    <span class="label">About</span>
    <p class="bio">
      Care about code that is easy to read and easy to change. Drawn to systems
      where the design decisions are visible in the code itself. Currently learning
      how good engineering teams build and ship at scale.
    </p>
  </section>


  <!-- Listening -->
  <section>
    <span class="label">Listening</span>
    <NowPlaying />
    <a href="/music" class="link" style="margin-top: 0.5rem;">music →</a>
  </section>
</Layout>

<style>
  /* Stack sections with consistent rhythm — fix missing inter-section gaps */
  header + section,
  section + section {
    margin-top: 1.75rem;
  }

  .display-name {
    font-family: var(--font-display);
    font-weight: 300;
    font-optical-sizing: auto;
    font-size: var(--text-2xl);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0.625rem;
  }

  .tagline {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.6;
  }

  .fg {
    color: var(--fg);
  }

  .role-list {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .bio {
    font-size: var(--text-base);
    color: var(--muted);
    max-width: 42ch;
    line-height: 1.65;
  }
</style>
