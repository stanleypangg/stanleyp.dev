---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Projects" description="Projects by Stanley Pang.">
  <div class="projects-wrap">
  <header class="page-header">
    <h1 class="page-title">Projects</h1>
    <p class="page-sub">{projects.length} projects</p>
  </header>
  <hr class="rule" />

  <ul class="index-list">
    {projects.map((project, i) => {
      const slug = project.id.replace(/\.mdx?$/, '');
      return (
        <li class="project-item">
          <div class="project-header entry">
            <a href={`/projects/${slug}`} class="project-title">
              {project.data.title}
            </a>
          </div>

          {project.data.award && (
            <span class="project-award">{project.data.award}</span>
          )}

          <p class="project-desc">{project.data.description}</p>

          <div class="project-footer">
            <span class="stack-inline">
              {project.data.stack.join(' · ')}
            </span>

            <div class="project-links">
              {project.data.links.live && (
                <a href={project.data.links.live} class="link" target="_blank" rel="noopener noreferrer">
                  Live ↗
                </a>
              )}
              {project.data.links.github && (
                <a href={project.data.links.github} class="link" target="_blank" rel="noopener noreferrer">
                  GitHub ↗
                </a>
              )}
              {project.data.links.devpost && (
                <a href={project.data.links.devpost} class="link" target="_blank" rel="noopener noreferrer">
                  Devpost ↗
                </a>
              )}
              <a href={`/projects/${slug}`} class="link">
                Read more →
              </a>
            </div>
          </div>
        </li>
      );
    })}
  </ul>
  </div>
</Layout>

<style>
  /* Fill available main height; list scrolls within.
     overflow: clip instead of hidden so focus rings on child links
     are not clipped (clip does not create a scroll container). */
  .projects-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: clip;
  }

  .page-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0;
    flex-shrink: 0;
  }

  .page-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-optical-sizing: auto;
    font-size: var(--text-lg);
    letter-spacing: -0.01em;
  }

  .page-sub {
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .project-item {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .project-title {
    font-size: var(--text-sm);
    font-weight: 300;
    display: inline-block;
    transition: color 200ms, transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .project-title:hover {
    color: var(--muted);
    transform: translateX(0.25rem);
  }
  /* Dark mode: grayscale antialiasing renders 300-weight thin; nudge to 400 */
  :global(html.dark) .project-title {
    font-weight: 400;
  }

  .project-award {
    font-size: var(--text-2xs);
    color: var(--subtle);
    letter-spacing: 0.04em;
    margin-top: -0.15rem;
  }

  .project-desc {
    font-size: var(--text-xs);
    color: var(--muted);
    line-height: 1.7;
    max-width: 48ch;
  }

  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.15rem;
  }

  .stack-inline {
    font-size: var(--text-2xs);
    color: var(--subtle);
    letter-spacing: 0.03em;
  }

  .project-links {
    display: flex;
    gap: 1.25rem;
    flex-shrink: 0;
  }

  /* ── Page entrance ─────────────────────────────────────────── */
  .page-header {
    animation: enter-up 800ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .index-list {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    min-height: 0;
    padding-top: 0.5rem;
    padding-bottom: 1rem;
    padding-right: 0.25rem;
    animation: enter-up 800ms cubic-bezier(0.16, 1, 0.3, 1) 110ms both;
  }

  /* Thin, minimal scrollbar */
  .index-list::-webkit-scrollbar        { width: 3px; }
  .index-list::-webkit-scrollbar-track  { background: transparent; }
  .index-list::-webkit-scrollbar-thumb  { background: var(--border); border-radius: 2px; }
  .index-list::-webkit-scrollbar-thumb:hover { background: var(--muted); }

  @media (prefers-reduced-motion: reduce) {
    .page-header,
    .index-list {
      animation: none;
    }
    .project-title {
      transition: color 200ms;
    }
    .project-title:hover {
      transform: none;
    }
  }
</style>
