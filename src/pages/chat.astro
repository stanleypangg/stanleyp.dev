---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Chat" description="Say something." noindex>
  <div class="chat-wrap">
    <header class="page-header">
      <h1 class="page-title">Chat</h1>
    </header>
    <hr class="rule" />

    <div class="chat-feed-wrap">
      <div class="chat-loader" id="chat-loader" aria-hidden="true">
        <div class="chat-spinner"></div>
      </div>
      <div
        class="chat-feed"
        id="chat-feed"
        role="log"
        aria-live="polite"
        aria-label="Chat messages"
      ></div>
      <button
        class="chat-scroll-btn"
        id="chat-scroll-btn"
        aria-label="Scroll to latest messages"
        tabindex="-1"
      >↓</button>
    </div>

    <dialog id="chat-blocked" class="chat-dialog" aria-labelledby="chat-blocked-msg">
      <p id="chat-blocked-msg">please don't send that.</p>
      <button autofocus>ok</button>
    </dialog>

    <form class="chat-form" id="chat-form" autocomplete="off" novalidate>
      <input
        type="text"
        id="chat-name"
        class="chat-input chat-input--name"
        placeholder="name"
        maxlength="32"
        required
        aria-label="Display name"
      />
      <div class="chat-msg-wrap">
        <input
          type="text"
          id="chat-msg"
          class="chat-input chat-input--msg"
          placeholder="say something..."
          maxlength="500"
          required
          aria-label="Message"
        />
        <output class="chat-char-left" id="chat-char-left" aria-hidden="true"></output>
      </div>
      <button type="submit" class="chat-send" aria-label="Send message">↵</button>
    </form>
  </div>
</Layout>

<script>
  import { createRealtimeClient } from '../lib/supabase-realtime';
  import type { RealtimeChannel } from '../lib/supabase-realtime';
  import type { ChatMessage } from '../lib/supabase';
  import { esc } from '../lib/music-utils';

  let channel: RealtimeChannel | null = null;
  let scrollIdleTimer: ReturnType<typeof setTimeout> | undefined;

  function formatTime(iso: string): string {
    const d = new Date(iso);
    return d.toLocaleDateString([], { month: 'short', day: 'numeric' })
      + ' ' + d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  }

  function renderMessage(msg: ChatMessage, isNew = false): string {
    return `<div class="chat-line${isNew ? ' chat-line--new' : ''}">
      <span class="chat-time">${formatTime(msg.created_at)}</span>
      <span class="chat-name">${esc(msg.display_name)}</span>
      <span class="chat-text">${esc(msg.content)}</span>
    </div>`;
  }

  function appendMessage(msg: ChatMessage) {
    const feed = document.getElementById('chat-feed');
    if (!feed) return;
    const empty = feed.querySelector('.chat-empty');
    if (empty) empty.remove();
    feed.insertAdjacentHTML('beforeend', renderMessage(msg, true));
    feed.scrollTop = feed.scrollHeight;
  }

  async function init() {
    const feed = document.getElementById('chat-feed');
    const form = document.getElementById('chat-form') as HTMLFormElement | null;
    const nameInput = document.getElementById('chat-name') as HTMLInputElement | null;
    const msgInput = document.getElementById('chat-msg') as HTMLInputElement | null;
    const loader = document.getElementById('chat-loader');
    const charLeft = document.getElementById('chat-char-left') as HTMLOutputElement | null;
    if (!feed || !form || !nameInput || !msgInput) return;
    const sendBtn = form.querySelector('button') as HTMLButtonElement | null;

    // Keep feed hidden while spinner shows
    feed.style.opacity = '0';

    // Restore saved display name
    try {
      const saved = localStorage.getItem('chat_display_name');
      if (saved) nameInput.value = saved.trim().slice(0, 32);
    } catch {}

    let messages: ChatMessage[] | null = null;
    let error = false;
    try {
      const res = await fetch('/api/chat');
      messages = res.ok ? await res.json() : null;
      error = !res.ok;
    } catch {
      error = true;
    }

    if (error || !messages) {
      feed.innerHTML = '<p class="chat-empty">failed to load messages.</p>';
    } else if (messages.length === 0) {
      feed.innerHTML = '<p class="chat-empty">no messages yet.</p>';
    } else {
      feed.innerHTML = messages.map((m) => renderMessage(m)).join('');
      feed.scrollTop = feed.scrollHeight;
    }

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reducedMotion) {
      // Spinner fades out as chat fades in simultaneously
      loader?.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 300, easing: 'ease-out', fill: 'forwards' });
      feed.animate([{ opacity: 0 }, { opacity: 1 }], { duration: 400, easing: 'ease-out', fill: 'forwards' });
    } else {
      feed.style.opacity = '';
      if (loader) loader.style.display = 'none';
    }
    if (error) return;

    // Realtime subscription
    const rtClient = createRealtimeClient();
    channel = rtClient
      .channel('chat-room')
      .on(
        'postgres_changes',
        { event: 'INSERT', schema: 'public', table: 'chat_messages' },
        (payload) => {
          const { id, display_name, content, created_at } = payload.new as Record<string, unknown>;
          appendMessage({ id, display_name, content, created_at } as ChatMessage);
        },
      )
      .subscribe();

    // Drag-to-scroll
    let isDragging = false;
    let startY = 0;
    let startScroll = 0;
    let lastY = 0;
    let velocity = 0;
    let rafId = 0;

    feed.addEventListener('pointerdown', (e) => {
      cancelAnimationFrame(rafId);
      isDragging = true;
      startY = e.clientY;
      lastY = e.clientY;
      startScroll = feed.scrollTop;
      velocity = 0;
      feed.setPointerCapture(e.pointerId);
      feed.classList.add('dragging');
    });

    feed.addEventListener('pointermove', (e) => {
      if (!isDragging) return;
      velocity = lastY - e.clientY;
      lastY = e.clientY;
      feed.scrollTop = startScroll - (e.clientY - startY);
    });

    feed.addEventListener('pointerup', () => {
      isDragging = false;
      feed.classList.remove('dragging');
      let v = velocity;
      function coast() {
        if (Math.abs(v) < 0.5) return;
        feed.scrollTop += v;
        v *= 0.92;
        rafId = requestAnimationFrame(coast);
      }
      rafId = requestAnimationFrame(coast);
    });

    // Scroll-to-bottom button
    const scrollBtn = document.getElementById('chat-scroll-btn') as HTMLButtonElement | null;

    function updateScrollBtn() {
      if (!scrollBtn) return;
      const atBottom = feed.scrollHeight - feed.scrollTop - feed.clientHeight < 60;
      scrollBtn.classList.toggle('visible', !atBottom);
    }

    scrollBtn?.addEventListener('click', () => {
      feed.scrollTo({ top: feed.scrollHeight, behavior: 'smooth' });
    });

    // Auto-hiding scrollbar + scroll-to-bottom sync + top fade
    const updateTopFade = () => feed.classList.toggle('at-top', feed.scrollTop === 0);
    feed.addEventListener('scroll', () => {
      feed.classList.add('is-scrolling');
      clearTimeout(scrollIdleTimer);
      scrollIdleTimer = setTimeout(() => {
        feed.classList.remove('is-scrolling');
      }, 1200);
      updateScrollBtn();
      updateTopFade();
    }, { passive: true });

    updateScrollBtn();
    updateTopFade();

    // Character counter — appears at ≤80 chars remaining
    msgInput.addEventListener('input', () => {
      if (!charLeft) return;
      const remaining = 500 - msgInput.value.length;
      charLeft.textContent = remaining.toString();
      charLeft.classList.toggle('visible', remaining <= 80);
    });

    // Form submit
    let sending = false;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (sending) return;

      const display_name = nameInput.value.trim();
      const content = msgInput.value.trim();
      if (!display_name || !content) return;

      sending = true;
      setFormState(form, true);

      try {
        localStorage.setItem('chat_display_name', display_name);
      } catch {}

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ display_name, content }),
        });

        if (res.ok) {
          msgInput.value = '';
          // Reset char counter
          if (charLeft) { charLeft.textContent = ''; charLeft.classList.remove('visible'); }
          // ↵ → ✓ flash
          if (sendBtn) {
            sendBtn.textContent = '✓';
            sendBtn.classList.add('chat-send--sent');
            setTimeout(() => {
              sendBtn.textContent = '↵';
              sendBtn.classList.remove('chat-send--sent');
            }, 550);
          }
        } else {
          const data: { error?: string } = await res.json().catch(() => ({ error: 'Send failed' }));
          if (res.status === 400 && data.error === 'Message contains prohibited content') {
            (document.getElementById('chat-blocked') as HTMLDialogElement)?.showModal();
          } else {
            showError(msgInput, data.error || 'Send failed');
          }
        }
      } catch {
        showError(msgInput, 'Network error');
      } finally {
        sending = false;
        setFormState(form, false);
        msgInput.focus();
      }
    });
  }

  let formTimeoutId: ReturnType<typeof setTimeout> | undefined;

  function setFormState(form: HTMLFormElement, disabled: boolean) {
    const btn = form.querySelector('button') as HTMLButtonElement | null;
    const inputs = form.querySelectorAll('input');
    if (btn) btn.disabled = disabled;
    inputs.forEach((i) => { (i as HTMLInputElement).style.opacity = disabled ? '0.5' : ''; });
    if (formTimeoutId) { clearTimeout(formTimeoutId); formTimeoutId = undefined; }
    if (disabled) {
      formTimeoutId = setTimeout(() => {
        if (btn) btn.disabled = false;
        inputs.forEach((i) => { (i as HTMLInputElement).style.opacity = ''; });
        formTimeoutId = undefined;
      }, 5000);
    }
  }

  function showError(input: HTMLInputElement, msg: string) {
    input.setCustomValidity(msg);
    input.reportValidity();
    setTimeout(() => input.setCustomValidity(''), 3000);
  }

  function cleanup() {
    if (channel) {
      channel.unsubscribe();
      channel = null;
    }
    clearTimeout(scrollIdleTimer);
  }

  document.addEventListener('astro:page-load', () => {
    init();
    const dialog = document.getElementById('chat-blocked') as HTMLDialogElement | null;
    dialog?.querySelector('button')?.addEventListener('click', () => dialog.close());
  });
  document.addEventListener('astro:before-swap', cleanup);
</script>

<style>
  /* ── Page wrapper — fills main flex column ─────────────── */
  .chat-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  /* ── Header ────────────────────────────────────────────── */
  .page-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    animation: enter-up 560ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .page-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-optical-sizing: auto;
    font-size: var(--text-lg);
    letter-spacing: -0.01em;
  }

  /* ── Constrain wrap/main to viewport on chat page ─────────── */
  :global(.wrap) { height: 100dvh; }
  :global(main)  { min-height: 0; }

  /* Override .rule margin-bottom so the feed clips right at the hr line */
  hr {
    margin-bottom: 0;
  }

  /* ── Feed wrapper — holds spinner overlay + scrollable feed ── */
  .chat-feed-wrap {
    flex: 1;
    position: relative;
    min-height: 0;
    overflow: hidden;
  }

  /* ── Spinner overlay ───────────────────────────────────── */
  .chat-loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .chat-spinner {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    border-top-color: var(--muted);
    animation: spin 0.9s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ── Feed ──────────────────────────────────────────────── */
  .chat-feed {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    cursor: grab;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.75rem 0.25rem 0.75rem 0;
    /* Older messages fade at top — suppressed when nothing is above */
    mask-image: linear-gradient(to bottom, transparent 0%, black 2rem);
  }

  .chat-feed.at-top { mask-image: none; }
  .chat-feed.dragging { cursor: grabbing; user-select: none; }

  /* ── Scroll-to-bottom button ───────────────────────────── */
  .chat-scroll-btn {
    position: absolute;
    bottom: 0.6rem;
    right: 0.5rem;
    width: 1.4rem;
    height: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-text);
    font-size: 0.6rem;
    line-height: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--subtle);
    cursor: pointer;
    border-radius: 50%;
    opacity: 0;
    translate: 0 4px;
    transition:
      opacity 220ms ease-out,
      translate 280ms cubic-bezier(0.16, 1, 0.3, 1),
      color 150ms,
      border-color 150ms;
    pointer-events: none;
  }

  .chat-scroll-btn.visible {
    opacity: 1;
    translate: 0 0;
    pointer-events: auto;
  }

  .chat-scroll-btn:hover {
    color: var(--fg);
    border-color: var(--muted);
  }

  .chat-feed::-webkit-scrollbar        { width: 2px; }
  .chat-feed::-webkit-scrollbar-track  { background: transparent; }
  .chat-feed::-webkit-scrollbar-thumb  {
    background: color-mix(in oklch, var(--border) 0%, transparent);
    border-radius: 2px;
    transition: background 450ms ease-out;
  }
  .chat-feed::-webkit-scrollbar-thumb:hover { background: var(--muted); }
  .chat-feed.is-scrolling::-webkit-scrollbar-thumb {
    background: var(--border);
    transition: background 120ms ease-in;
  }

  /* :global() — innerHTML-injected message elements */
  :global(.chat-line) {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: var(--text-xs);
    font-family: var(--font-text);
    font-weight: 300;
    line-height: 1.6;
  }

  :global(.chat-line--new) {
    animation: msg-in 220ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  :global(.chat-time) {
    color: var(--subtle);
    font-size: var(--text-2xs);
    font-variant-numeric: tabular-nums;
    width: 7.5rem;
    flex-shrink: 0;
  }

  :global(.chat-name) {
    color: var(--fg);
    font-weight: 300;
    width: 6rem;
    flex-shrink: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.chat-name)::after {
    content: ':';
    color: var(--subtle);
  }

  :global(.chat-text) {
    color: var(--muted);
    word-break: break-word;
  }

  .chat-empty {
    font-size: var(--text-xs);
    color: var(--subtle);
    font-family: var(--font-text);
    font-weight: 300;
  }


  /* ── Form ──────────────────────────────────────────────── */
  .chat-form {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
    flex-shrink: 0;
    animation: enter-up 560ms cubic-bezier(0.16, 1, 0.3, 1) 150ms both;
  }

  .chat-input {
    font-family: var(--font-text);
    font-size: var(--text-xs);
    font-weight: 300;
    color: var(--fg);
    /* Underline grows from center on focus — two-layer background technique */
    background-color: transparent;
    background-image:
      linear-gradient(var(--fg), var(--fg)),
      linear-gradient(var(--border), var(--border));
    background-size: 0% 1px, 100% 1px;
    background-position: bottom center, bottom;
    background-repeat: no-repeat;
    border: none;
    padding: 0.4rem 0;
    outline: none;
    transition: background-size 260ms cubic-bezier(0.16, 1, 0.3, 1), opacity 200ms;
  }

  .chat-input::placeholder {
    color: var(--subtle);
  }

  .chat-input:focus {
    background-size: 100% 1px, 100% 1px;
  }

  /* Keyboard focus: restore visible indicator suppressed by outline:none */
  .chat-input:focus-visible {
    outline: 1.5px solid var(--fg);
    outline-offset: 3px;
    border-radius: 1px;
  }

  .chat-input--name { width: 7rem; flex-shrink: 0; }
  .chat-input--msg  { width: 100%; }

  /* Wrapper gives --msg its flex slot and anchors the char counter */
  .chat-msg-wrap {
    flex: 1;
    min-width: 0;
    position: relative;
  }

  /* Character counter — fades in near the limit */
  .chat-char-left {
    position: absolute;
    top: -1.2rem;
    right: 0;
    font-size: var(--text-2xs);
    font-family: var(--font-text);
    font-variant-numeric: tabular-nums;
    color: var(--subtle);
    line-height: 1;
    opacity: 0;
    transition: opacity 200ms;
    pointer-events: none;
    user-select: none;
  }

  .chat-char-left.visible {
    opacity: 1;
  }

  .chat-send {
    font-family: var(--font-text);
    font-size: var(--text-sm);
    color: var(--subtle);
    background: none;
    border: none;
    cursor: pointer;
    /* 44×44px minimum touch target */
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 1;
    transition: color 200ms, transform 150ms cubic-bezier(0.16, 1, 0.3, 1);
    margin-right: -0.5rem; /* optical alignment */
  }

  .chat-send:hover   { color: var(--fg); }
  .chat-send:active  { color: var(--muted); transform: scale(0.82); }
  .chat-send:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  /* Sent confirmation flash */
  .chat-send--sent { color: var(--muted); }

  /* ── Blocked dialog ────────────────────────────────────── */
  .chat-dialog {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg);
    color: var(--fg);
    padding: 1.5rem 2rem;
    max-width: 280px;
    width: 90%;
    position: fixed;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    margin: 0;
  }

  .chat-dialog::backdrop {
    background: oklch(0% 0 0 / 0.4);
  }

  .chat-dialog p {
    font-family: var(--font-text);
    font-size: var(--text-sm);
    font-weight: 300;
    margin: 0 0 1.25rem;
  }

  .chat-dialog button {
    font-family: var(--font-text);
    font-size: var(--text-xs);
    font-weight: 300;
    color: var(--subtle);
    background: none;
    border: none;
    border-bottom: 1px solid var(--border);
    padding: 0.2rem 0;
    cursor: pointer;
    transition: color 200ms;
  }

  .chat-dialog button:hover { color: var(--fg); }

  /* ── Animations ────────────────────────────────────────── */
  @keyframes msg-in {
    from { opacity: 0; translate: 0 4px; }
    to   { opacity: 1; translate: 0 0;  }
  }

  /* ── Reduced motion ────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .page-header,
    .chat-form {
      animation: none;
    }
    :global(.chat-line--new) {
      animation: none;
    }
    .chat-spinner {
      animation: none;
    }
    /* Remove spatial/size transitions — keep color/opacity only */
    .chat-input {
      transition: opacity 200ms;
    }
    .chat-send {
      transition: color 200ms, opacity 200ms;
    }
    .chat-char-left {
      transition: none;
    }
    .chat-scroll-btn {
      transition: opacity 200ms, color 150ms, border-color 150ms;
      translate: none;
    }
    .chat-scroll-btn.visible {
      translate: none;
    }
  }
</style>
