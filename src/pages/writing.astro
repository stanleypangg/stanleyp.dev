---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const fmt = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' });

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Writing" description="Writing by Stanley Pang.">
  <div class="writing-wrap">
    <header class="page-header">
      <h1 class="page-title">Writing</h1>
      {posts.length > 0 && (
        <p class="page-sub">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
      )}
    </header>
    <hr class="rule" />

    {posts.length === 0 ? (
      <p class="empty">Nothing here yet.</p>
    ) : (
      <ul class="index-list">
        {posts.map((post) => (
          <li class="post-item">
            <div class="entry">
              <a href={`/writing/${post.id.replace(/\.mdx?$/, '')}`} class="post-title">
                {post.data.title}
              </a>
              <span class="entry-meta">{fmt.format(post.data.date)}</span>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>

<style>
  .writing-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: clip;
    padding-top: 0.125rem;
  }

  /* ── Page entrance ─────────────────────────────────────────── */
  .index-list,
  .empty {
    animation: enter-fade 800ms ease-out 110ms both;
  }

  .index-list {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    min-height: 0;
    padding-top: 0.5rem;
    padding-bottom: 1rem;
    padding-right: 0.25rem;
  }

  /* Thin, minimal scrollbar */
  .index-list::-webkit-scrollbar        { width: 3px; }
  .index-list::-webkit-scrollbar-track  { background: transparent; }
  .index-list::-webkit-scrollbar-thumb  { background: var(--border); border-radius: 2px; }
  .index-list::-webkit-scrollbar-thumb:hover { background: var(--muted); }

  .page-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    animation: enter-fade 800ms ease-out both;
  }

  .page-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-optical-sizing: auto;
    font-size: var(--text-lg);
    letter-spacing: -0.01em;
  }

  .page-sub {
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .post-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .post-title {
    font-size: var(--text-sm);
    font-weight: 300;
    transition: color 200ms, transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
    display: inline-block;
  }
  .post-title:hover {
    color: var(--muted);
    transform: translateX(0.25rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .page-header,
    .index-list,
    .empty {
      animation: none;
    }
    .post-title {
      transition: color 200ms;
    }
    .post-title:hover {
      transform: none;
    }
  }
</style>
