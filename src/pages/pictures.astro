---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PicturesGallery from '../components/PicturesGallery.astro';
import photoMeta from '../data/photo-order.json';

// Cache at Vercel's CDN edge: serve cached for 1h, revalidate in background for up to 24h
Astro.response.headers.set('Cache-Control', 's-maxage=3600, stale-while-revalidate=86400');

const skPhotos = photoMeta
  .filter((p): p is { id: string; w: number; h: number } => typeof p === 'object' && 'w' in p)
  .slice(0, 12);
const skLeft = skPhotos.filter((_, i) => i % 2 === 0);
const skRight = skPhotos.filter((_, i) => i % 2 !== 0);

---

<Layout title="Pictures" description="Photos by Stanley Pang.">
  <section data-pictures-root>
    <PicturesGallery server:defer>
      <div slot="fallback" id="skeleton-screen" aria-hidden="true">
        <div class="sk-grid">
          <div class="sk-col sk-left">
            {skLeft.map((p, i) => (
              <div class="sk-wrap" style={`animation-delay: ${(i * 2 % 5) * 130}ms`}>
                <img width={p.w} height={p.h} alt="" class="sk-sizer" />
              </div>
            ))}
          </div>
          <div class="sk-col sk-right">
            {skRight.map((p, i) => (
              <div class="sk-wrap" style={`animation-delay: ${((i * 2 + 1) % 5) * 130}ms`}>
                <img width={p.w} height={p.h} alt="" class="sk-sizer" />
              </div>
            ))}
          </div>
        </div>
      </div>
    </PicturesGallery>
  </section>

  <dialog id="lightbox" class="lightbox" aria-label="Photo viewer">
    <div class="lb-adj-wrap" id="lb-adj-prev" aria-hidden="true">
      <img class="lb-adj-img" src="" alt="" draggable="false" />
    </div>
    <div class="lb-adj-wrap" id="lb-adj-next" aria-hidden="true">
      <img class="lb-adj-img" src="" alt="" draggable="false" />
    </div>
    <div class="lightbox-content">
      <button class="lightbox-close" aria-label="Close">&times;</button>
      <img class="lightbox-img" src="" alt="" draggable="false" />
      <div class="lightbox-meta">
        <span class="lightbox-caption"></span>
      </div>
      <div class="lightbox-controls">
        <button class="lightbox-btn lightbox-prev" aria-label="Previous photo">&larr;</button>
        <span class="lightbox-counter" role="status" aria-live="polite"></span>
        <button class="lightbox-btn lightbox-next" aria-label="Next photo">&rarr;</button>
      </div>
    </div>
  </dialog>
</Layout>

<style>
  .sk-grid {
    display: flex;
    gap: 0.5rem;
    margin-top: -1rem;
  }

  .sk-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sk-left {
    padding-left: 5px;
  }

  .sk-right {
    padding-right: 5px;
  }

  .sk-wrap {
    border-radius: 6px;
    overflow: hidden;
    background:
      linear-gradient(
        to bottom,
        oklch(from var(--border) l c h / 0.72),
        oklch(from var(--border) l c h / 0.54)
      ),
      radial-gradient(
        circle at 50% 18%,
        oklch(from var(--bg) l c h / 0.12),
        transparent 58%
      );
    animation: photo-skeleton-breathe 1.6s ease-in-out infinite;
  }

  .sk-sizer {
    width: 100%;
    height: auto;
    display: block;
    visibility: hidden;
  }

  /* ── Adjacent image overlays (shown during drag) ───────────── */

  .lb-adj-wrap {
    position: fixed;
    inset: 0;
    display: none; /* shown via JS */
    align-items: center;
    justify-content: center;
    pointer-events: none;
    will-change: transform;
    backface-visibility: hidden;
  }

  .lb-adj-img {
    width: min(90vw, 1100px);
    height: 70dvh;
    object-fit: contain;
    object-position: top center;
    border-radius: 4px;
    display: block;
    user-select: none;
    will-change: transform;
    backface-visibility: hidden;
  }

  /* ── Lightbox ─────────────────────────────────────────────── */

  .lightbox {
    border: none;
    background: transparent;
    padding: 0;
    /* display must NOT be set here — author display overrides UA display:none
       for closed dialogs, making the element visible and blocking interactions */
  }

  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 100dvw;
    max-height: 100dvh;
    width: 100%;
    height: 100%;
    overflow: hidden;
    touch-action: none; /* prevent browser from hijacking horizontal swipes */

    /* Lightbox UI tokens — always on the dark overlay, so these are fixed neutrals */
    --lb-ui:       oklch(92% 0 0);  /* controls: close, prev, next */
    --lb-ui-hover: oklch(100% 0 0); /* controls: hover */
    --lb-dim:      oklch(80% 0 0);  /* counter */
    --lb-caption:  oklch(75% 0 0);  /* caption text */
  }

  .lightbox::backdrop {
    background: oklch(0% 0 0 / 0.6);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  .lightbox-content {
    position: relative;
    max-width: min(90vw, 1100px);
    max-height: 85dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .lightbox-img {
    width: min(90vw, 1100px);
    height: 70dvh;
    object-fit: contain;
    object-position: top center;
    border-radius: 4px;
    filter: saturate(1);
    display: block;
    cursor: grab;
    user-select: none;
    will-change: transform, opacity;
    backface-visibility: hidden;
  }

  .lightbox-img.is-loading {
    opacity: 0;
  }

  @keyframes lb-out-left {
    to {
      opacity: 0;
      transform: translate3d(-28px, 0, 0) scale(0.985);
    }
  }
  @keyframes lb-out-right {
    to {
      opacity: 0;
      transform: translate3d(28px, 0, 0) scale(0.985);
    }
  }
  @keyframes lb-in-left {
    from {
      opacity: 0;
      transform: translate3d(-28px, 0, 0) scale(0.992);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }
  @keyframes lb-in-right {
    from {
      opacity: 0;
      transform: translate3d(28px, 0, 0) scale(0.992);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  .lightbox-img.lb-out-left  { animation: lb-out-left  210ms cubic-bezier(0.4, 0, 1, 1) both; }
  .lightbox-img.lb-out-right { animation: lb-out-right 210ms cubic-bezier(0.4, 0, 1, 1) both; }
  .lightbox-img.lb-in-left   { animation: lb-in-left   320ms cubic-bezier(0.16, 1, 0.3, 1) both; }
  .lightbox-img.lb-in-right  { animation: lb-in-right  320ms cubic-bezier(0.16, 1, 0.3, 1) both; }

  .lightbox-close {
    position: absolute;
    top: -2.25rem;
    right: -0.5rem;
    font-family: var(--font-text);
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--lb-ui);
    background: none;
    border: none;
    cursor: pointer;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 150ms ease;
    line-height: 1;
  }

  .lightbox-close:hover {
    color: var(--lb-ui-hover);
  }

  .lightbox-close:focus-visible,
  .lightbox-btn:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .lightbox-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    text-align: center;
  }

  .lightbox-meta:empty {
    display: none;
  }

  .lightbox-caption {
    font-family: var(--font-text);
    font-size: var(--text-xs);
    font-weight: 300;
    color: var(--lb-caption);
  }

  .lightbox-caption:empty {
    display: none;
  }

.lightbox-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .lightbox-btn {
    font-family: var(--font-text);
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--lb-ui);
    background: none;
    border: none;
    cursor: pointer;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 150ms ease;
    line-height: 1;
  }

  .lightbox-btn:hover {
    color: var(--lb-ui-hover);
  }

  .lightbox-counter {
    font-family: var(--font-text);
    font-size: var(--text-2xs);
    font-weight: 300;
    color: var(--lb-dim);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
    min-width: 5ch;
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox::backdrop {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }

  @media (max-width: 600px) {
    .lightbox-content {
      max-width: 95vw;
    }

    .lightbox-close {
      top: -2.5rem;
      right: 0;
    }
  }
</style>

<script>
  const GAP = 8; // px between items vertically

  function measureHeight(item: HTMLElement): number {
    const wrap = item.querySelector<HTMLElement>('.photo-wrap');
    const img = item.querySelector<HTMLImageElement>('img');
    if (!wrap || !img) return 0;

    const styles = window.getComputedStyle(item);
    const padTop = parseFloat(styles.paddingTop) || 0;
    const padBottom = parseFloat(styles.paddingBottom) || 0;

    let h = wrap.getBoundingClientRect().height + padTop + padBottom;
    if (h === padTop + padBottom) {
      // Estimate from declared aspect ratio before image loads.
      const aw = Number(img.getAttribute('width'));
      const ah = Number(img.getAttribute('height'));
      const w = img.getBoundingClientRect().width;
      if (aw && ah && w > 0) h = w * (ah / aw) + padTop + padBottom;
    }
    return h;
  }

  function spanItem(item: HTMLElement) {
    const h = measureHeight(item);
    if (h === 0) return;
    item.style.gridRowEnd = `span ${Math.round(h) + GAP}`;
  }

  function spanAll() {
    // Batch reads first, then writes — avoids layout thrashing
    const items = Array.from(document.querySelectorAll<HTMLElement>('.photo-item'));
    const heights = items.map(measureHeight);                          // all reads
    items.forEach((item, i) => {                                       // all writes
      if (heights[i] > 0) item.style.gridRowEnd = `span ${Math.round(heights[i]) + GAP}`;
    });
  }

  function updateOuterPadding() {
    const grid = document.querySelector<HTMLElement>('.photo-grid');
    if (!grid) return;

    const gridRect = grid.getBoundingClientRect();
    const gridMidX = gridRect.left + gridRect.width / 2;
    const items = Array.from(grid.querySelectorAll<HTMLElement>('.photo-item'));

    // Batch reads — one layout computation for all items
    const isLeft = items.map(item => {
      const rect = item.getBoundingClientRect();
      return (rect.left + rect.width / 2) < gridMidX;
    });

    // Batch writes — class toggles no longer interleave with reads
    items.forEach((item, i) => {
      item.classList.toggle('is-left-column', isLeft[i]);
      item.classList.toggle('is-right-column', !isLeft[i]);
    });
  }

  // ── Reveal queue — batches concurrent decodes into one layout pass ──
  let revealQueue: HTMLElement[] = [];
  let revealRaf = 0;

  function queueReveal(item: HTMLElement) {
    revealQueue.push(item);
    if (!revealRaf) revealRaf = requestAnimationFrame(flushReveals);
  }

  function flushReveals() {
    revealRaf = 0;
    const batch = revealQueue;
    revealQueue = [];

    // Batch reads
    const heights = batch.map(measureHeight);
    // Batch writes
    batch.forEach((item, i) => {
      if (heights[i] > 0) item.style.gridRowEnd = `span ${Math.round(heights[i]) + GAP}`;
      item.style.transitionDelay = '0ms';
    });

    updateOuterPadding();
    spanAll();

    // Add .is-ready in next frame after layout settles
    requestAnimationFrame(() => {
      batch.forEach(item => item.classList.add('is-ready'));
    });
  }

  // ── Lightbox state ────────────────────────────────────────────
  type Photo = { src: string; alt: string; date: string; caption?: string };
  let currentIndex = 0;
  let lightboxPhotos: Photo[] = [];
  let lbController: AbortController | null = null;
  let savedFocus: HTMLElement | null = null;
  let lightboxImageToken = 0;
  let galleryObserver: MutationObserver | null = null;

  const prefetched = new Set<string>();
  function prefetchImage(url: string) {
    if (prefetched.has(url)) return;
    prefetched.add(url);
    const img = new Image();
    img.src = url;
  }

  function prefetchAdjacent() {
    const len = lightboxPhotos.length;
    if (len < 2) return;
    prefetchImage(lightboxPhotos[(currentIndex + 1) % len].src);
    prefetchImage(lightboxPhotos[(currentIndex - 1 + len) % len].src);
  }

  function getPhotos(): Photo[] {
    const el = document.getElementById('photo-data');
    if (!el) return [];
    try { return JSON.parse(el.textContent || '[]'); } catch { return []; }
  }

  function updateLightbox(options: { hideUntilLoaded?: boolean } = {}) {
    const photo = lightboxPhotos[currentIndex];
    if (!photo) return;
    const img = document.querySelector<HTMLImageElement>('.lightbox-img');
    const counter = document.querySelector<HTMLElement>('.lightbox-counter');
    const caption = document.querySelector<HTMLElement>('.lightbox-caption');
    const hideUntilLoaded = options.hideUntilLoaded === true;
    if (img) {
      const token = ++lightboxImageToken;
      const reveal = () => {
        if (token !== lightboxImageToken) return;
        img.classList.remove('is-loading');
      };

      if (hideUntilLoaded) {
        img.classList.add('is-loading');
        img.removeAttribute('src');
      }

      img.alt = photo.alt;
      img.src = photo.src;

      if (hideUntilLoaded) {
        if (img.complete) {
          requestAnimationFrame(reveal);
        } else {
          img.addEventListener('load', reveal, { once: true });
          img.addEventListener('error', reveal, { once: true });
        }
      }
    }
    if (counter) counter.textContent = `${currentIndex + 1} / ${lightboxPhotos.length}`;
    if (caption) caption.textContent = photo.caption || '';
  }

  function openLightbox(index: number) {
    const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
    if (!dialog) return;
    lightboxPhotos = getPhotos();
    if (lightboxPhotos.length === 0) return;
    currentIndex = index;
    updateLightbox({ hideUntilLoaded: true });
    savedFocus = document.activeElement as HTMLElement | null;
    dialog.showModal();
    dialog.querySelector<HTMLButtonElement>('.lightbox-close')?.focus();
    prefetchAdjacent();
  }

  function onLightboxImageReady(img: HTMLImageElement, callback: () => void) {
    const start = () => requestAnimationFrame(() => requestAnimationFrame(callback));
    if (img.complete && img.currentSrc) {
      start();
      return;
    }
    img.addEventListener('load', start, { once: true });
    img.addEventListener('error', start, { once: true });
  }

  function closeLightbox() {
    const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
    dialog?.close();
    savedFocus?.focus();
    savedFocus = null;
  }

  function navigate(delta: number) {
    const len = lightboxPhotos.length;
    if (len === 0) return;

    const img = document.querySelector<HTMLImageElement>('.lightbox-img');
    if (!img) {
      currentIndex = (currentIndex + delta + len) % len;
      updateLightbox();
      return;
    }

    const outClass = delta > 0 ? 'lb-out-left' : 'lb-out-right';
    const inClass  = delta > 0 ? 'lb-in-right' : 'lb-in-left';

    // Clear any in-flight animation before starting a new one
    img.classList.remove('lb-out-left', 'lb-out-right', 'lb-in-left', 'lb-in-right');
    void img.offsetWidth; // force reflow to restart animation

    img.classList.add(outClass);
    img.addEventListener('animationend', () => {
      img.style.opacity = '0';
      img.classList.remove(outClass);
      currentIndex = (currentIndex + delta + len) % len;
      updateLightbox({ hideUntilLoaded: true });

      onLightboxImageReady(img, () => {
        img.style.opacity = '';
        img.classList.add(inClass);
        img.addEventListener('animationend', () => img.classList.remove(inClass), { once: true });
        prefetchAdjacent();
      });
    }, { once: true });
  }

  function init() {
    // ── Hide footer/wave until gallery loads ────────────────
    const footer = document.querySelector<HTMLElement>('.site-footer');
    const wave   = document.querySelector<HTMLElement>('.wave-wrap');
    if (!document.querySelector('[data-pictures-gallery]')) {
      [footer, wave].forEach(el => { if (el) el.style.opacity = '0'; });
    }

    // Masonry grid sizing + staggered fade-in
    document.querySelectorAll<HTMLImageElement>('.photo-img').forEach((img) => {
      const item = img.closest('.photo-item') as HTMLElement;

      // decode() off the main thread, then queue batched reveal
      const onLoaded = () => {
        img.decode().then(
          () => queueReveal(item),
          () => queueReveal(item)
        );
      };

      if (img.complete) {
        onLoaded();
      } else {
        img.addEventListener('load', onLoaded, { once: true });
      }
    });

    // Initial layout — batched reads then writes, no per-item thrashing
    updateOuterPadding();
    spanAll();

    // Abort previous listeners before re-attaching.
    // init() runs twice on first load (direct call + astro:page-load), which would
    // double every listener and cause navigate() to fire twice per click.
    lbController?.abort();
    lbController = new AbortController();
    const { signal } = lbController;

    // ── Drag-to-scroll on the photo grid ─────────────────────
    const grid = document.querySelector<HTMLElement>('.photo-grid');
    let gridDragActive = false;
    let gridScrollEl: Element | null = null;
    let gridStartX = 0;
    let gridStartY = 0;
    let gridScrollStartX = 0;
    let gridScrollStartY = 0;
    let gridLastX = 0;
    let gridLastY = 0;
    let gridVelX = 0;
    let gridVelY = 0;
    let gridWasDragging = false;
    let gridRafId = 0;
    const GRID_THRESHOLD = 5;

    if (grid) {
      grid.addEventListener('pointerdown', (e: PointerEvent) => {
        if (e.button !== 0) return;
        cancelAnimationFrame(gridRafId);
        gridDragActive = false;
        gridWasDragging = false;
        gridStartX = e.clientX;
        gridStartY = e.clientY;
        gridLastX = e.clientX;
        gridLastY = e.clientY;
        gridVelX = 0;
        gridVelY = 0;
        // Scroll on the document root (the page itself)
        gridScrollEl = document.scrollingElement || document.documentElement;
        gridScrollStartX = gridScrollEl.scrollLeft;
        gridScrollStartY = gridScrollEl.scrollTop;
        // NOTE: do NOT capture pointer here — that would steal click events from photo-wraps.
        // Capture only once drag threshold is crossed (see pointermove).
      }, { signal });

      grid.addEventListener('pointermove', (e: PointerEvent) => {
        if (!gridScrollEl) return;
        const dx = e.clientX - gridStartX;
        const dy = e.clientY - gridStartY;
        if (!gridDragActive) {
          if (Math.hypot(dx, dy) < GRID_THRESHOLD) return;
          gridDragActive = true;
          grid.classList.add('is-dragging');
          grid.setPointerCapture(e.pointerId);
        }
        e.preventDefault();
        gridVelX = gridLastX - e.clientX;
        gridVelY = gridLastY - e.clientY;
        gridLastX = e.clientX;
        gridLastY = e.clientY;
        gridScrollEl.scrollLeft = gridScrollStartX - dx;
        gridScrollEl.scrollTop  = gridScrollStartY - dy;
      }, { signal, passive: false });

      const endGridDrag = (cancelled: boolean) => {
        const wasActive = gridDragActive;
        gridDragActive = false;
        grid.classList.remove('is-dragging');

        if (!wasActive || cancelled) { gridScrollEl = null; return; }

        gridWasDragging = true;
        requestAnimationFrame(() => { gridWasDragging = false; });

        const el = gridScrollEl;
        gridScrollEl = null;
        if (!el) return;
        let vx = gridVelX;
        let vy = gridVelY;
        let cLeft = el.scrollLeft;
        let cTop  = el.scrollTop;
        const coast = () => {
          if (Math.abs(vx) < 0.5 && Math.abs(vy) < 0.5) return;
          cLeft += vx;
          cTop  += vy;
          el.scrollLeft = cLeft;
          el.scrollTop  = cTop;
          vx *= 0.92;
          vy *= 0.92;
          gridRafId = requestAnimationFrame(coast);
        };
        gridRafId = requestAnimationFrame(coast);
      };

      grid.addEventListener('pointerup', () => endGridDrag(false), { signal });
      grid.addEventListener('pointercancel', () => endGridDrag(true), { signal });
    }

    // ── Lightbox ─────────────────────────────────────────────
    const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
    if (!dialog) return;

    document.querySelectorAll<HTMLElement>('.photo-item').forEach((item, i) => {
      const wrap = item.querySelector<HTMLElement>('.photo-wrap');
      if (!wrap) return;
      wrap.addEventListener('click', () => {
        if (gridWasDragging) return;
        openLightbox(i);
      }, { signal });
      wrap.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLightbox(i); }
      }, { signal });
    });

    dialog.querySelector('.lightbox-prev')?.addEventListener('click', () => navigate(-1), { signal });
    dialog.querySelector('.lightbox-next')?.addEventListener('click', () => navigate(1), { signal });
    dialog.querySelector('.lightbox-close')?.addEventListener('click', closeLightbox, { signal });

    // Guard: suppress backdrop-close click if a drag just ended
    let wasDragging = false;

    dialog.addEventListener('click', (e: MouseEvent) => {
      if (wasDragging) return;
      if (e.target === dialog) closeLightbox();
    }, { signal });

    dialog.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); navigate(-1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); navigate(1); }
    }, { signal });

    // ── Pointer-based drag / swipe (mouse + touch) ────────────────
    // adj overlays sit at ±100vw, all three elements translate by the same dx
    const adjPrevWrap = document.getElementById('lb-adj-prev') as HTMLElement | null;
    const adjNextWrap = document.getElementById('lb-adj-next') as HTMLElement | null;

    interface DragState {
      startX: number; startY: number; delta: number; dragging: boolean;
      sign: -1 | 1;   // -1 = going to prev, +1 = going to next
      adjBase: number; // off-screen offset for the active adj (±vw)
    }
    let dragState: DragState | null = null;
    let activeAdj: HTMLElement | null = null;
    const DRAG_THRESHOLD = 80;

    const syncAdjacentFrame = (adjWrap: HTMLElement, sourceImg: HTMLImageElement) => {
      const adjImg = adjWrap.querySelector<HTMLImageElement>('.lb-adj-img');
      if (!adjImg) return;

      const rect = sourceImg.getBoundingClientRect();
      adjWrap.style.display = 'block';

      adjImg.style.position = 'absolute';
      adjImg.style.left = `${rect.left}px`;
      adjImg.style.top = `${rect.top}px`;
      adjImg.style.width = `${rect.width}px`;
      adjImg.style.height = `${rect.height}px`;
      adjImg.style.maxWidth = 'none';
    };

    const hideAdj = () => {
      if (!activeAdj) return;
      activeAdj.querySelector<HTMLElement>('.lb-adj-img')?.removeAttribute('style');
      activeAdj.style.cssText = '';
      activeAdj = null;
    };

    dialog.addEventListener('pointerdown', (e: PointerEvent) => {
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      dragState = { startX: e.clientX, startY: e.clientY, delta: 0, dragging: false, sign: 1, adjBase: 0 };
    }, { signal });

    dialog.addEventListener('pointermove', (e: PointerEvent) => {
      if (!dragState) return;
      const dx = e.clientX - dragState.startX;
      const dy = e.clientY - dragState.startY;

      if (!dragState.dragging) {
        if (Math.abs(dx) < 8) return;
        if (Math.abs(dy) > Math.abs(dx)) { dragState = null; return; }
        dragState.dragging = true;
        dialog.setPointerCapture(e.pointerId);
        dialog.style.cursor = 'grabbing';

        // Determine direction and prepare adjacent image
        const sign: -1 | 1 = dx > 0 ? -1 : 1; // drag right = prev, drag left = next
        dragState.sign = sign;
        const adjBase = sign * window.innerWidth; // prev: -vw (left), next: +vw (right)
        dragState.adjBase = adjBase;

        const adjIndex = (currentIndex + sign + lightboxPhotos.length) % lightboxPhotos.length;
        activeAdj = sign === -1 ? adjPrevWrap : adjNextWrap;
        if (activeAdj) {
          const img = dialog.querySelector<HTMLImageElement>('.lightbox-img');
          const adjImg = activeAdj.querySelector<HTMLImageElement>('.lb-adj-img');
          if (adjImg) { adjImg.src = lightboxPhotos[adjIndex].src; adjImg.alt = lightboxPhotos[adjIndex].alt; }
          if (img) syncAdjacentFrame(activeAdj, img);
          activeAdj.style.transform = `translate3d(${adjBase}px, 0, 0)`;
        }
      }

      dragState.delta = dx;
      const img = dialog.querySelector<HTMLImageElement>('.lightbox-img');
      if (img) { img.style.transition = 'none'; img.style.transform = `translate3d(${dx}px, 0, 0)`; }
      if (activeAdj) { activeAdj.style.transition = 'none'; activeAdj.style.transform = `translate3d(${dragState.adjBase + dx}px, 0, 0)`; }
    }, { signal });

    const releaseDrag = () => {
      if (!dragState) return;
      const { dragging, delta, sign, adjBase } = dragState;
      dragState = null;
      dialog.style.cursor = '';
      if (!dragging) { hideAdj(); return; }

      wasDragging = true;
      requestAnimationFrame(() => { wasDragging = false; });

      const img = dialog.querySelector<HTMLImageElement>('.lightbox-img');
      if (!img) { hideAdj(); return; }

      const EASING = 'cubic-bezier(0.4, 0, 0.2, 1)';
      const SNAP   = 'cubic-bezier(0.25, 1, 0.5, 1)';

      if (Math.abs(delta) > DRAG_THRESHOLD && activeAdj) {
        // Commit: slide current off, adj comes to center
        const exitX = delta > 0 ? window.innerWidth : -window.innerWidth;
        img.style.transition = `transform 200ms ${EASING}`;
        img.style.transform = `translate3d(${exitX}px, 0, 0)`;
        activeAdj.style.transition = `transform 200ms ${EASING}`;
        activeAdj.style.transform = 'translate3d(0, 0, 0)';

        const adj = activeAdj;
        img.addEventListener('transitionend', () => {
          currentIndex = (currentIndex + sign + lightboxPhotos.length) % lightboxPhotos.length;
          updateLightbox({ hideUntilLoaded: true });
          img.style.transition = 'none';
          img.style.transform = '';
          adj.querySelector<HTMLElement>('.lb-adj-img')?.removeAttribute('style');
          adj.style.cssText = '';
          if (activeAdj === adj) activeAdj = null;
        }, { once: true });
      } else {
        // Snap back: both return to starting positions
        img.style.transition = `transform 280ms ${SNAP}`;
        img.style.transform = '';
        img.addEventListener('transitionend', () => { img.style.transition = ''; }, { once: true });

        if (activeAdj) {
          const adj = activeAdj;
          adj.style.transition = `transform 280ms ${SNAP}`;
          adj.style.transform = `translate3d(${adjBase}px, 0, 0)`;
          adj.addEventListener('transitionend', () => {
            adj.style.cssText = '';
            if (activeAdj === adj) activeAdj = null;
          }, { once: true });
        }
      }
    };

    dialog.addEventListener('pointerup', releaseDrag, { signal });
    dialog.addEventListener('pointercancel', () => {
      dragState = null;
      dialog.style.cursor = '';
      const img = dialog.querySelector<HTMLImageElement>('.lightbox-img');
      if (img) { img.style.transition = 'none'; img.style.transform = ''; }
      hideAdj();
    }, { signal });
  }

  function showFooter() {
    const footer = document.querySelector<HTMLElement>('.site-footer');
    const wave   = document.querySelector<HTMLElement>('.wave-wrap');
    [footer, wave].forEach(el => {
      if (!el) return;
      el.style.transition = 'opacity 500ms ease';
      el.style.opacity = '';
      el.addEventListener('transitionend', () => { el.style.transition = ''; }, { once: true });
    });
  }

  function observeGallery() {
    const root = document.querySelector<HTMLElement>('[data-pictures-root]');
    if (!root) return;

    if (root.querySelector('[data-pictures-gallery]')) {
      showFooter();
      init();
      return;
    }

    galleryObserver?.disconnect();
    galleryObserver = new MutationObserver(() => {
      if (root.querySelector('[data-pictures-gallery]')) {
        galleryObserver?.disconnect();
        showFooter();
        init();
      }
    });
    galleryObserver.observe(root, { childList: true, subtree: true });
  }

  document.addEventListener('astro:page-load', () => {
    init();
    observeGallery();
  });
  let resizeRaf = 0;
  window.addEventListener('resize', () => {
    cancelAnimationFrame(resizeRaf);
    resizeRaf = requestAnimationFrame(() => {
      spanAll();
      updateOuterPadding();
    });
  });
</script>
